@model RecipeHelper.Models.Kroger.KrogerProductDto
@{
    ViewData["Title"]    = "Product";
    ViewData["NavTitle"] = Model.name?.Length > 22 ? Model.name.Substring(0, 22) + "…" : Model.name;
    ViewData["BackLink"] = Url.Action("Products", "Product");
    ViewData["BackLabel"] = "Products";
    var productId = ViewBag.ProductId;
}

@section NavRight {
    <form asp-action="DeleteProduct" asp-controller="Product" method="post" id="deleteForm" class="inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="productId" value="@productId" />
        <button type="submit" class="ios-btn-text-destructive">Delete</button>
    </form>
}

<div class="pt-2 pb-6">

    @if (TempData["WarningMessage"] is string warn && !string.IsNullOrWhiteSpace(warn))
    {
        <div id="warningMessage" class="mx-4 mb-3 rounded-2xl px-4 py-3 text-[14px]"
             style="background: #FFFBE6; color: #7A5900; position: relative;">
            &#9888; @warn
            <button type="button" class="absolute top-2 right-3 text-lg"
                    onclick="document.getElementById('warningMessage').style.display='none';">&times;</button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div id="errorMessage" class="mx-4 mb-3 rounded-2xl px-4 py-3 text-[14px]"
             style="background: #FFF0F0; color: var(--ios-red); position: relative;">
            @err
            <button type="button" class="absolute top-2 right-3 text-lg"
                    onclick="document.getElementById('errorMessage').style.display='none';">&times;</button>
        </div>
    }

    <!-- Product image -->
    <div class="flex justify-center px-4 pb-4">
        <div class="rounded-2xl overflow-hidden" style="background: var(--ios-surface); box-shadow: 0 4px 16px rgba(0,0,0,0.08);">
            <img src="https://www.kroger.com/product/images/medium/front/@Model.upc"
                 alt="@Model.name"
                 class="h-52 w-52 object-contain p-3" />
        </div>
    </div>

    <!-- Name (inline edit) -->
    <div class="px-4 pb-3">
        <div class="flex items-center gap-2">
            <h1 id="productNameText" class="text-[22px] font-bold flex-1" style="color: var(--ios-label);">@Model.name</h1>
            <button id="editNameBtn" type="button" class="ios-btn-text-sm p-1.5 rounded-lg" style="background: var(--ios-fill);">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M17.414 2.586a2 2 0 00-2.828 0L6 11.172V14h2.828l8.586-8.586a2 2 0 000-2.828z" />
                    <path fill-rule="evenodd" d="M4 16h12a1 1 0 110 2H4a1 1 0 110-2z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
        <input id="productNameInput" type="text" value="@Model.name" class="hidden field-input w-full mt-2" />
        <div id="nameEditBtns" class="hidden flex gap-2 mt-2">
            <button id="saveNameBtn" type="button" class="btn-primary flex-1" style="padding-top: 8px; padding-bottom: 8px; font-size:14px;">Save</button>
            <button id="cancelNameBtn" type="button" class="btn-secondary flex-1" style="padding-top: 8px; padding-bottom: 8px; font-size:14px;">Cancel</button>
        </div>
        <div id="statusMsg" class="hidden mt-2 text-[13px]"></div>
    </div>

    <!-- Details -->
    <p class="ios-section-hdr">Details</p>
    <div class="ios-group">
        <div class="ios-cell justify-between">
            <span class="text-[15px]" style="color: var(--ios-label-2);">Size</span>
            <span class="text-[15px] font-medium" style="color: var(--ios-label);">@(Model.size ?? "—")</span>
        </div>
        <div class="ios-cell justify-between">
            <span class="text-[15px]" style="color: var(--ios-label-2);">Sold By</span>
            <span class="text-[15px] font-medium" style="color: var(--ios-label);">@(Model.soldBy ?? "—")</span>
        </div>
        <div class="ios-cell justify-between">
            <span class="text-[15px]" style="color: var(--ios-label-2);">Stock</span>
            <span class="text-[15px] font-medium" style="color: var(--ios-label);">@(Model.stockLevel ?? "—")</span>
        </div>
        @if (Model.categories != null && Model.categories.Any())
        {
            <div class="ios-cell justify-between">
                <span class="text-[15px]" style="color: var(--ios-label-2);">Category</span>
                <span class="text-[13px] font-medium text-right" style="color: var(--ios-label); max-width: 60%;">@string.Join(", ", Model.categories)</span>
            </div>
        }
        <div class="ios-cell justify-between">
            <span class="text-[15px]" style="color: var(--ios-label-2);">Price</span>
            @if (Model.onSale)
            {
                <div class="text-right">
                    <span class="text-[17px] font-bold" style="color: #34C759;">$@Model.promoPrice.ToString("0.00")</span>
                    <span class="text-[13px] line-through ml-1" style="color: var(--ios-label-2);">$@Model.regularPrice.ToString("0.00")</span>
                </div>
            }
            else
            {
                <span class="text-[17px] font-bold" style="color: var(--ios-label);">$@Model.regularPrice.ToString("0.00")</span>
            }
        </div>
    </div>
</div>

<!-- hidden form for anti-forgery token -->
<form id="afForm" method="post" class="hidden">
    @Html.AntiForgeryToken()
</form>

<script>
    (function () {
        const nameText   = document.getElementById('productNameText');
        const nameInput  = document.getElementById('productNameInput');
        const editBtns   = document.getElementById('nameEditBtns');
        const btnEdit    = document.getElementById('editNameBtn');
        const btnSave    = document.getElementById('saveNameBtn');
        const btnCancel  = document.getElementById('cancelNameBtn');
        const statusMsg  = document.getElementById('statusMsg');

        const productId = @productId;
        const updateUrl = '@Url.Action("UpdateProduct", "Product")';
        const token = document.querySelector('#afForm input[name="__RequestVerificationToken"]').value;

        function setEditing(editing) {
            nameText.classList.toggle('hidden', editing);
            nameInput.classList.toggle('hidden', !editing);
            editBtns.classList.toggle('hidden', !editing);
            btnEdit.classList.toggle('hidden', editing);
            if (editing) {
                nameInput.value = nameText.textContent.trim();
                nameInput.focus();
                nameInput.select();
            }
        }

        function showStatus(text, ok) {
            statusMsg.textContent = text;
            statusMsg.classList.remove('hidden');
            statusMsg.style.color = ok ? '#34C759' : 'var(--ios-red)';
            setTimeout(() => { statusMsg.classList.add('hidden'); }, 3000);
        }

        btnEdit.addEventListener('click', () => setEditing(true));
        btnCancel.addEventListener('click', () => setEditing(false));

        nameInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') { e.preventDefault(); btnSave.click(); }
            if (e.key === 'Escape') { e.preventDefault(); btnCancel.click(); }
        });

        btnSave.addEventListener('click', async () => {
            const newName = nameInput.value.trim();
            if (!newName) { showStatus('Name cannot be empty.', false); return; }
            if (newName === nameText.textContent.trim()) { setEditing(false); return; }

            try {
                const body = new URLSearchParams({
                    productId: String(productId),
                    updatedProductName: newName,
                    __RequestVerificationToken: token
                });

                const resp = await fetch(updateUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body
                });

                if (!resp.ok) {
                    let msg = 'Update failed.';
                    try { const j = await resp.json(); if (j?.error) msg = j.error; } catch {}
                    showStatus(msg, false);
                    if (resp.status === 400 || resp.status === 401) location.reload();
                    return;
                }

                if (resp.status === 200) {
                    const j = await resp.json();
                    nameText.textContent = j.name ?? newName;
                }
                setEditing(false);
                showStatus('Product name updated.', true);
            } catch (err) {
                console.error(err);
                showStatus('Network error updating product.', false);
            }
        });

        (function () {
            var w = document.getElementById('warningMessage');
            var e = document.getElementById('errorMessage');
            if (w) setTimeout(function () { w.style.display = 'none'; }, 5000);
            if (e) setTimeout(function () { e.style.display = 'none'; }, 5000);
        })();

        document.getElementById('deleteForm')?.addEventListener('submit', (e) => {
            if (!confirm('Delete this product?')) e.preventDefault();
        });
    })();
</script>
