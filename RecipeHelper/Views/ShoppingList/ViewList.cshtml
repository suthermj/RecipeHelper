@model RecipeHelper.Models.Lists.ShoppingList

@{
    ViewData["Title"] = Model.Name;

    var krogerBrands = new[] { "kroger", "simple truth", "private selection", "hemisfares" };
    bool IsKrogerBrand(string? brand) =>
        brand != null && krogerBrands.Any(b => brand.Contains(b, StringComparison.OrdinalIgnoreCase));

    decimal GetDisplayPrice(RecipeHelper.Models.Lists.ShoppingListItem item)
    {
        var basePrice = (item.PromoPrice > 0 ? item.PromoPrice : item.Price) ?? 0;
        return IsKrogerBrand(item.Brand) ? Math.Round(basePrice * 0.9m, 2) : basePrice;
    }

    var pending = Model.Items.Where(i => !i.IsCompleted).ToList();
    var completed = Model.Items.Where(i => i.IsCompleted).ToList();

    // Special sections pulled out first
    var produce = pending.Where(i => i.AisleDescription?.Contains("PRODUCE", StringComparison.OrdinalIgnoreCase) == true).ToList();
    var meat    = pending.Where(i => i.AisleDescription?.Contains("MEAT", StringComparison.OrdinalIgnoreCase) == true).ToList();
    var dairy   = pending.Where(i => i.AisleDescription?.Contains("DAIRY", StringComparison.OrdinalIgnoreCase) == true).ToList();
    var special = produce.Concat(meat).Concat(dairy).Select(i => i.Id).ToHashSet();

    // Remaining items grouped by aisle number, sorted numerically
    var byAisle = pending
        .Where(i => !special.Contains(i.Id) && i.AisleNumber != null)
        .GroupBy(i => i.AisleNumber!)
        .OrderBy(g => int.TryParse(g.Key, out var n) ? n : 999)
        .ToList();

    var noAisle = pending.Where(i => !special.Contains(i.Id) && i.AisleNumber == null).ToList();

    // Estimated subtotal (pending items only)
    var subtotal = pending.Where(i => i.Price.HasValue || i.PromoPrice.HasValue)
                          .Sum(i => GetDisplayPrice(i) * i.Quantity);
}

<style>
  body.shopping-mode [data-shopping-mode-hide] { display: none !important; }
</style>

<div class="max-w-3xl mx-auto px-4 py-6 space-y-4 pb-32">
    <!-- Header -->
    <div>
        <a asp-action="Index"
           class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3 transition">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            All Lists
        </a>
        <div data-shopping-mode-hide>
            <form asp-action="Rename" method="post" class="flex items-center gap-2" id="renameForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input name="name" type="text" value="@Model.Name"
                       class="text-2xl font-bold text-gray-900 bg-transparent border-0 border-b-2 border-transparent focus:border-red-700 focus:ring-0 p-0 flex-1 min-w-0"
                       id="listNameInput" />
                <button type="submit" id="renameBtn"
                        class="hidden text-sm text-red-800 font-semibold hover:text-red-900 whitespace-nowrap">Save</button>
            </form>
            <div class="flex items-center justify-between mt-1.5">
                <p class="text-xs text-gray-500">@Model.CreatedDate.ToLocalTime().ToString("MMM d, yyyy")</p>
                <div class="flex items-center gap-3">
                    <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this list?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="text-sm text-red-600 hover:text-red-800 font-medium">Delete</button>
                    </form>
                    <button id="startShoppingBtn"
                            data-current-store-id="@ViewData["CurrentStoreId"]"
                            class="px-4 py-2 rounded-full text-sm font-semibold bg-green-600 text-white hover:bg-green-700 transition">
                        Shop mode
                    </button>
                </div>
            </div>
        </div>

        <!-- Shopping mode header (shown only when in shopping mode) -->
        <div id="shoppingModeHeader" class="hidden">
            <h1 class="text-2xl font-bold text-gray-900">@Model.Name</h1>
            <div class="flex items-center gap-2 mt-0.5">
                <p class="text-sm text-gray-500" id="shopModeStoreName">@ViewData["CurrentStoreName"]</p>
                <button id="changeStoreBtn" class="text-xs text-blue-600 hover:text-blue-800 font-medium transition">Change store</button>
            </div>
            <button id="exitShoppingBtn"
                    class="mt-3 px-4 py-2 rounded-full text-sm font-semibold bg-gray-700 text-white hover:bg-gray-800 transition">
                Exit shopping
            </button>
        </div>
    </div>

    <!-- Add item -->
    <form asp-action="AddItem" method="post" class="flex gap-2" data-shopping-mode-hide>
        @Html.AntiForgeryToken()
        <input type="hidden" name="listId" value="@Model.Id" />
        <input name="name" type="text" required placeholder="Add an item..."
               class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-red-700 focus:ring-2 focus:ring-red-700" />
        <input name="quantity" type="number" value="1" min="1"
               class="w-16 rounded-lg border border-gray-300 px-2 py-2 text-sm text-center focus:border-red-700 focus:ring-2 focus:ring-red-700" />
        <button type="submit"
                class="px-4 py-2 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">Add</button>
    </form>

    @if (pending.Count == 0 && completed.Count == 0)
    {
        <div class="text-center py-12">
            <p class="text-sm text-gray-500">This list is empty. Add items above.</p>
        </div>
    }
    else
    {
        <!-- Numbered aisle sections -->
        @foreach (var aisleGroup in byAisle)
        {
            <div data-section-wrapper>
                <div class="bg-gray-700 text-white font-bold text-base px-4 py-2 rounded-t-lg">
                    Aisle @aisleGroup.Key
                </div>
                <div class="divide-y divide-gray-100 border border-t-0 border-gray-200 rounded-b-lg overflow-hidden">
                    @foreach (var item in aisleGroup)
                    {
                        @await Html.PartialAsync("_ShoppingListItem", item, new ViewDataDictionary(ViewData) { { "listId", Model.Id } })
                    }
                </div>
            </div>
        }

        <!-- Special sections -->
        @foreach (var (label, items) in new[] {
            ("Produce", produce),
            ("Meat & Seafood", meat),
            ("Dairy", dairy),
        }.Where(s => s.Item2.Count > 0))
        {
            <div data-section-wrapper>
                <div class="bg-gray-700 text-white font-bold text-base px-4 py-2 rounded-t-lg">
                    @label
                </div>
                <div class="divide-y divide-gray-100 border border-t-0 border-gray-200 rounded-b-lg overflow-hidden">
                    @foreach (var item in items)
                    {
                        @await Html.PartialAsync("_ShoppingListItem", item, new ViewDataDictionary(ViewData) { { "listId", Model.Id } })
                    }
                </div>
            </div>
        }

        <!-- No aisle info -->
        @if (noAisle.Count > 0)
        {
            <div data-section-wrapper>
                <div class="bg-gray-500 text-white font-bold text-base px-4 py-2 rounded-t-lg">
                    Other
                </div>
                <div class="divide-y divide-gray-100 border border-t-0 border-gray-200 rounded-b-lg overflow-hidden">
                    @foreach (var item in noAisle)
                    {
                        @await Html.PartialAsync("_ShoppingListItem", item, new ViewDataDictionary(ViewData) { { "listId", Model.Id } })
                    }
                </div>
            </div>
        }

        <!-- Completed -->
        @if (completed.Count > 0)
        {
            <div>
                <div class="bg-gray-200 text-gray-600 font-bold text-base px-4 py-2 rounded-t-lg">
                    Completed (@completed.Count)
                </div>
                <div class="divide-y divide-gray-100 border border-t-0 border-gray-200 rounded-b-lg overflow-hidden">
                    @foreach (var item in completed)
                    {
                        <div class="flex items-center gap-3 bg-gray-50 px-4 py-3.5">
                            <form asp-action="UpdateItem" method="post" class="flex items-center" data-complete-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <input type="hidden" name="listId" value="@Model.Id" />
                                <input type="hidden" name="isCompleted" value="false" />
                                <button type="submit" class="h-6 w-6 rounded border-2 border-green-500 bg-green-500 flex-shrink-0 flex items-center justify-center p-0.5">
                                    <svg class="h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                </button>
                            </form>
                            <div class="flex-1">
                                <span class="text-sm text-gray-400 line-through">@item.Name</span>
                                <p class="text-xs text-gray-400">QTY @item.Quantity</p>
                            </div>
                            <form asp-action="RemoveItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <input type="hidden" name="listId" value="@Model.Id" />
                                <button type="submit" class="text-gray-300 hover:text-red-600 transition">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<!-- Estimated Subtotal bar -->
@if (subtotal > 0)
{
    <div class="fixed bottom-16 inset-x-0 bg-white border-t border-gray-200 px-4 py-3 z-30" data-shopping-mode-hide>
        <div class="max-w-3xl mx-auto flex items-center justify-between">
            <span class="text-sm font-semibold text-gray-700">Estimated Subtotal</span>
            <span class="text-sm font-bold text-gray-900">$@subtotal.ToString("0.00")</span>
        </div>
    </div>
}

<!-- Store mismatch modal -->
<div id="storeMismatchModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 px-4">
    <div class="bg-white rounded-xl shadow-xl max-w-sm w-full p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-900">Closer store found</h2>
        <div class="text-sm space-y-2">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Current store</p>
                <p class="text-gray-700 font-medium">@ViewData["CurrentStoreName"]</p>
            </div>
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Closer store</p>
                <p class="text-gray-700 font-semibold" id="nearbyStoreName"></p>
                <p class="text-gray-500 text-xs" id="nearbyStoreAddress"></p>
            </div>
        </div>
        <p class="text-sm text-gray-600">Switch stores so aisle locations stay accurate?</p>
        <div class="flex gap-3 pt-1">
            <button id="switchStoreBtn"
                    class="flex-1 py-2 rounded-full text-sm font-semibold bg-green-600 text-white hover:bg-green-700 transition">
                Switch to this store
            </button>
            <button id="keepStoreBtn"
                    class="flex-1 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                Keep current store
            </button>
        </div>
    </div>
</div>

<!-- Change store modal (shop mode) -->
<div id="changeStoreModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 px-4">
    <div class="bg-white rounded-xl shadow-xl max-w-sm w-full p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-bold text-gray-900">Change store</h2>
            <button id="closeChangeStoreBtn" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
        </div>
        <div class="flex gap-2">
            <input id="storeZipInput" type="text" placeholder="ZIP code"
                   class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" />
            <button id="storeZipSearchBtn"
                    class="px-3 py-2 rounded-lg text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                Search
            </button>
        </div>
        <button id="storeUseLocationBtn"
                class="w-full py-2 rounded-lg text-sm text-blue-600 hover:text-blue-800 font-medium transition flex items-center justify-center gap-1">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Use my location
        </button>
        <p id="changeStoreLoading" class="hidden text-sm text-gray-500 text-center">Searching…</p>
        <div id="changeStoreResults" class="space-y-2 max-h-52 overflow-y-auto"></div>
    </div>
</div>

@section Scripts {
<script>
    const nameInput = document.getElementById('listNameInput');
    const renameBtn = document.getElementById('renameBtn');
    const originalName = nameInput.value;

    nameInput.addEventListener('input', () => {
        const changed = nameInput.value.trim() !== originalName && nameInput.value.trim().length > 0;
        renameBtn.classList.toggle('hidden', !changed);
    });

    // Restore scroll position after complete-toggle reload
    const savedScroll = sessionStorage.getItem('shoppingScrollY');
    if (savedScroll) { window.scrollTo(0, +savedScroll); sessionStorage.removeItem('shoppingScrollY'); }

    // Save scroll before complete-toggle (full page reload)
    document.querySelectorAll('[data-complete-form]').forEach(function (form) {
        form.addEventListener('submit', function () {
            sessionStorage.setItem('shoppingScrollY', window.scrollY);
        });
    });

    // AJAX: quantity +/-
    document.querySelectorAll('[data-qty-form]').forEach(function (form) {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const fd = new FormData(this);
            const itemId = fd.get('itemId');
            const newQty = parseInt(fd.get('quantity'));
            try {
                const res = await fetch(this.action, { method: 'POST', body: fd });
                if (!res.ok) throw new Error();
            } catch { location.reload(); return; }

            const row = document.getElementById('item-' + itemId);
            if (!row) return;
            row.querySelector('[data-qty-display]').textContent = newQty;
            const dec = row.querySelector('[data-dec-btn]');
            const inc = row.querySelector('[data-inc-btn]');
            dec.value = newQty - 1;
            inc.value = newQty + 1;
            dec.disabled = newQty <= 1;
            dec.classList.toggle('opacity-30', newQty <= 1);
            dec.classList.toggle('pointer-events-none', newQty <= 1);
        });
    });

    // AJAX: remove item
    document.querySelectorAll('[data-remove-form]').forEach(function (form) {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const fd = new FormData(this);
            const itemId = fd.get('itemId');
            try {
                const res = await fetch(this.action, { method: 'POST', body: fd });
                if (!res.ok) throw new Error();
            } catch { location.reload(); return; }

            const row = document.getElementById('item-' + itemId);
            if (!row) return;
            const section = row.closest('[data-section-wrapper]');
            row.remove();
            if (section && section.querySelectorAll('[id^="item-"]').length === 0) {
                section.remove();
            }
        });
    });

    // Shopping mode
    const startShoppingBtn = document.getElementById('startShoppingBtn');
    const exitShoppingBtn  = document.getElementById('exitShoppingBtn');
    const shoppingModeHeader = document.getElementById('shoppingModeHeader');
    const storeModal = document.getElementById('storeMismatchModal');
    const nearbyStoreNameEl    = document.getElementById('nearbyStoreName');
    const nearbyStoreAddressEl = document.getElementById('nearbyStoreAddress');
    const switchStoreBtn = document.getElementById('switchStoreBtn');
    const keepStoreBtn   = document.getElementById('keepStoreBtn');
    const currentStoreId = startShoppingBtn.dataset.currentStoreId;
    let pendingNearbyStore = null;

    function enterShoppingMode() {
        document.body.classList.add('shopping-mode');
        shoppingModeHeader.classList.remove('hidden');
    }

    function exitShoppingMode() {
        document.body.classList.remove('shopping-mode');
        shoppingModeHeader.classList.add('hidden');
    }

    startShoppingBtn.addEventListener('click', function () {
        if (!navigator.geolocation) { enterShoppingMode(); return; }
        navigator.geolocation.getCurrentPosition(
            async function (position) {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                try {
                    const res = await fetch('/Settings/SearchStoresByLocation?latitude=' + lat + '&longitude=' + lng);
                    if (!res.ok) throw new Error();
                    const results = await res.json();
                    if (results && results.length > 0 && results[0].locationId !== currentStoreId) {
                        pendingNearbyStore = results[0];
                        nearbyStoreNameEl.textContent    = results[0].name ?? '';
                        nearbyStoreAddressEl.textContent = results[0].address ?? '';
                        storeModal.classList.remove('hidden');
                    } else {
                        enterShoppingMode();
                    }
                } catch {
                    enterShoppingMode();
                }
            },
            function () { enterShoppingMode(); }
        );
    });

    exitShoppingBtn.addEventListener('click', exitShoppingMode);

    // Change store (manual, inside shop mode)
    const changeStoreBtn     = document.getElementById('changeStoreBtn');
    const changeStoreModal   = document.getElementById('changeStoreModal');
    const closeChangeStoreBtn = document.getElementById('closeChangeStoreBtn');
    const storeZipInput      = document.getElementById('storeZipInput');
    const storeZipSearchBtn  = document.getElementById('storeZipSearchBtn');
    const storeUseLocationBtn = document.getElementById('storeUseLocationBtn');
    const changeStoreLoading = document.getElementById('changeStoreLoading');
    const changeStoreResults = document.getElementById('changeStoreResults');

    changeStoreBtn.addEventListener('click', function () {
        changeStoreModal.classList.remove('hidden');
        changeStoreResults.innerHTML = '';
        storeZipInput.value = '';
    });

    closeChangeStoreBtn.addEventListener('click', function () {
        changeStoreModal.classList.add('hidden');
    });

    async function selectStoreAndRefresh(store) {
        const fd = new FormData();
        fd.append('locationId', store.locationId);
        fd.append('storeName', store.name);
        if (store.latitude  != null) fd.append('latitude',  store.latitude);
        if (store.longitude != null) fd.append('longitude', store.longitude);
        try { await fetch('/Settings/SelectStore', { method: 'POST', body: fd }); } catch {}
        try {
            await fetch('/ShoppingList/RefreshAisles?id=@Model.Id&storeId=' + encodeURIComponent(store.locationId), { method: 'POST' });
        } catch {}
        location.reload();
    }

    function renderChangeStoreResults(stores) {
        changeStoreLoading.classList.add('hidden');
        changeStoreResults.innerHTML = '';
        if (!stores || stores.length === 0) {
            changeStoreResults.innerHTML = '<p class="text-sm text-gray-500 text-center">No stores found.</p>';
            return;
        }
        stores.forEach(function (store) {
            const btn = document.createElement('button');
            btn.className = 'w-full text-left px-3 py-2 rounded-lg border border-gray-200 hover:border-blue-400 hover:bg-blue-50 transition text-sm';
            btn.innerHTML = '<span class="font-semibold text-gray-800">' + store.name + '</span>' +
                (store.address ? '<br><span class="text-xs text-gray-500">' + store.address + '</span>' : '');
            btn.addEventListener('click', async function () {
                btn.disabled = true;
                btn.innerHTML = '<span class="text-gray-400">Switching & updating aisles…</span>';
                await selectStoreAndRefresh(store);
            });
            changeStoreResults.appendChild(btn);
        });
    }

    storeZipSearchBtn.addEventListener('click', async function () {
        const zip = storeZipInput.value.trim();
        if (!zip) return;
        changeStoreResults.innerHTML = '';
        changeStoreLoading.classList.remove('hidden');
        try {
            const res = await fetch('/Settings/SearchStores?zipCode=' + encodeURIComponent(zip));
            renderChangeStoreResults(await res.json());
        } catch {
            changeStoreLoading.classList.add('hidden');
            changeStoreResults.innerHTML = '<p class="text-sm text-red-500 text-center">Error searching. Try again.</p>';
        }
    });

    storeZipInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') storeZipSearchBtn.click();
    });

    storeUseLocationBtn.addEventListener('click', function () {
        if (!navigator.geolocation) return;
        changeStoreResults.innerHTML = '';
        changeStoreLoading.classList.remove('hidden');
        navigator.geolocation.getCurrentPosition(
            async function (position) {
                try {
                    const res = await fetch('/Settings/SearchStoresByLocation?latitude=' + position.coords.latitude + '&longitude=' + position.coords.longitude);
                    renderChangeStoreResults(await res.json());
                } catch {
                    changeStoreLoading.classList.add('hidden');
                    changeStoreResults.innerHTML = '<p class="text-sm text-red-500 text-center">Error searching. Try again.</p>';
                }
            },
            function () {
                changeStoreLoading.classList.add('hidden');
                changeStoreResults.innerHTML = '<p class="text-sm text-red-500 text-center">Location access denied.</p>';
            }
        );
    });

    keepStoreBtn.addEventListener('click', function () {
        storeModal.classList.add('hidden');
        enterShoppingMode();
    });

    switchStoreBtn.addEventListener('click', async function () {
        if (!pendingNearbyStore) return;
        switchStoreBtn.disabled = true;
        switchStoreBtn.textContent = 'Updating aisle locations…';

        const fd = new FormData();
        fd.append('locationId', pendingNearbyStore.locationId);
        fd.append('storeName',  pendingNearbyStore.name);
        if (pendingNearbyStore.latitude  != null) fd.append('latitude',  pendingNearbyStore.latitude);
        if (pendingNearbyStore.longitude != null) fd.append('longitude', pendingNearbyStore.longitude);
        try { await fetch('/Settings/SelectStore', { method: 'POST', body: fd }); } catch {}

        try {
            await fetch('/ShoppingList/RefreshAisles?id=@Model.Id&storeId=' + encodeURIComponent(pendingNearbyStore.locationId), { method: 'POST' });
        } catch {}

        location.reload();
    });
</script>
}
