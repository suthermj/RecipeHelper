@model List<RecipeHelper.Models.Lists.ShoppingList>

@{
    ViewData["Title"] = "Shopping Lists";
}

<div class="max-w-3xl mx-auto px-4 py-6 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Shopping Lists</h1>
        <button type="button" id="newListBtn"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            New List
        </button>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-16">
            <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
            </svg>
            <p class="mt-3 text-sm text-gray-500">No shopping lists yet.</p>
            <p class="text-sm text-gray-400">Create one or generate from a meal plan.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var list in Model)
            {
                var itemCount = list.Items?.Count ?? 0;
                <a asp-action="ViewList" asp-route-id="@list.Id"
                   class="block rounded-xl border border-gray-200 bg-white p-4 hover:border-gray-300 hover:shadow-sm transition">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="font-semibold text-gray-900">@list.Name</h2>
                            <p class="text-xs text-gray-500 mt-0.5">
                                @list.CreatedDate.ToLocalTime().ToString("MMM d, yyyy") &middot; @itemCount @(itemCount == 1 ? "item" : "items")
                            </p>
                        </div>
                        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                    </div>
                </a>
            }
        </div>
    }
</div>

<!-- New list modal -->
<div id="newListModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50 p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Create Shopping List</h3>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input name="name" type="text" required placeholder="List name..."
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-red-700 focus:ring-2 focus:ring-red-700" />
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" id="cancelNewList"
                        class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">Cancel</button>
                <button type="submit"
                        class="px-4 py-2 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const modal = document.getElementById('newListModal');
    document.getElementById('newListBtn').addEventListener('click', () => {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.querySelector('input').focus();
    });
    document.getElementById('cancelNewList').addEventListener('click', () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    });
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    });
</script>
}
