@model RecipeHelper.Models.Lists.ShoppingListItem

@{
    var listId = (int)ViewData["listId"]!;
    var krogerBrands = new[] { "kroger", "simple truth", "private selection", "hemisfares" };
    bool isKrogerBrand = Model.Brand != null &&
        krogerBrands.Any(b => Model.Brand.Contains(b, StringComparison.OrdinalIgnoreCase));

    decimal? displayPrice = null;
    bool onSale = false;

    if (Model.PromoPrice.HasValue && Model.PromoPrice > 0)
    {
        displayPrice = Model.PromoPrice;
        onSale = true;
    }
    else if (Model.Price.HasValue && Model.Price > 0)
    {
        displayPrice = Model.Price;
    }

    decimal? discountedPrice = isKrogerBrand && displayPrice.HasValue
        ? Math.Round(displayPrice.Value * 0.9m, 2)
        : null;
}

<div class="flex items-center gap-3 rounded-lg bg-white border border-gray-200 px-4 py-3">
    <!-- Complete checkbox -->
    <form asp-action="UpdateItem" method="post" class="flex items-center">
        @Html.AntiForgeryToken()
        <input type="hidden" name="itemId" value="@Model.Id" />
        <input type="hidden" name="listId" value="@listId" />
        <input type="hidden" name="isCompleted" value="true" />
        <button type="submit" class="h-5 w-5 rounded border-2 border-gray-300 hover:border-green-500 transition flex-shrink-0"
                title="Mark complete"></button>
    </form>

    <!-- Name + brand/price -->
    <div class="flex-1 min-w-0">
        <span class="text-sm text-gray-900">@Model.Name</span>
        @if (displayPrice.HasValue)
        {
            <div class="flex items-center gap-1.5 mt-0.5 flex-wrap">
                @if (isKrogerBrand && discountedPrice.HasValue)
                {
                    <span class="text-xs font-semibold text-white bg-green-600 rounded px-1 py-0.5">-10%</span>
                    <span class="text-xs font-semibold text-green-700">$@discountedPrice.Value.ToString("0.00")</span>
                    <span class="text-xs text-gray-400 line-through">$@displayPrice.Value.ToString("0.00")</span>
                }
                else if (onSale && Model.Price.HasValue)
                {
                    <span class="text-xs font-semibold text-green-700">$@displayPrice.Value.ToString("0.00")</span>
                    <span class="text-xs text-gray-400 line-through">$@Model.Price.Value.ToString("0.00")</span>
                }
                else
                {
                    <span class="text-xs text-gray-500">$@displayPrice.Value.ToString("0.00")</span>
                }
            </div>
        }
    </div>

    <!-- Quantity +/- -->
    <div class="flex items-center gap-1 shrink-0">
        <form asp-action="UpdateItem" method="post" class="flex items-center">
            @Html.AntiForgeryToken()
            <input type="hidden" name="itemId" value="@Model.Id" />
            <input type="hidden" name="listId" value="@listId" />
            <button type="submit" name="quantity" value="@(Model.Quantity - 1)"
                    class="h-6 w-6 rounded-full border border-gray-300 text-gray-600 hover:border-red-400 hover:text-red-600 transition text-sm leading-none flex items-center justify-center @(Model.Quantity <= 1 ? "opacity-30 pointer-events-none" : "")"
                    @(Model.Quantity <= 1 ? "disabled" : "")>−</button>
        </form>
        <span class="w-5 text-center text-sm font-medium text-gray-800">@Model.Quantity</span>
        <form asp-action="UpdateItem" method="post" class="flex items-center">
            @Html.AntiForgeryToken()
            <input type="hidden" name="itemId" value="@Model.Id" />
            <input type="hidden" name="listId" value="@listId" />
            <button type="submit" name="quantity" value="@(Model.Quantity + 1)"
                    class="h-6 w-6 rounded-full border border-gray-300 text-gray-600 hover:border-green-500 hover:text-green-600 transition text-sm leading-none flex items-center justify-center">+</button>
        </form>
    </div>

    <!-- Remove -->
    <form asp-action="RemoveItem" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="itemId" value="@Model.Id" />
        <input type="hidden" name="listId" value="@listId" />
        <button type="submit" class="text-gray-400 hover:text-red-600 transition" title="Remove">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </form>
</div>
