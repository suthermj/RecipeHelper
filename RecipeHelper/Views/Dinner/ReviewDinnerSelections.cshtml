@using RecipeHelper.Models.Kroger
@using RecipeHelper.Models.Dinner
@model ReviewDinnerSelectionsVM

<div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
    <!-- existing header + selected recipes stuff above... -->
    <!-- Ingredients -->
    <section class="space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900">Combined ingredients</h2>
            <p class="text-xs text-gray-500">
                Uncheck items you already have at home. Only checked ingredients will be added to your Kroger cart.
            </p>
        </div>

        @if (Model.Ingredients == null || !Model.Ingredients.Any())
        {
            <p class="text-sm text-gray-500">
                No ingredients to display. Make sure you’ve selected at least one recipe.
            </p>
        }
        else
        {
            <!-- Start form -->
            <form asp-controller="Cart"
                  asp-action="PreviewAddToCart"
                  method="post"
                  id="add-to-kroger-form"
                  class="space-y-4 loading-form"
                  data-loading-text="Building Kroger cart items...">
                @Html.AntiForgeryToken()

                <div class="overflow-x-auto bg-white rounded-2xl shadow-sm border border-gray-200">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium text-gray-600">
                                    Ingredient
                                </th>
                                <th class="px-4 py-3 text-left font-medium text-gray-600">
                                    Quantity needed
                                </th>
                                <th class="px-4 py-3 text-left font-medium text-gray-600 text-center">
                                    Include in cart
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @for (var i = 0; i < Model.Ingredients.Count; i++)
                            {
                                var item = Model.Ingredients[i];

                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3 align-top">
                                        <span class="font-medium text-gray-900">
                                            @item.Name
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 align-top">
                                        <span class="text-gray-800 font-medium">
                                            @item.DisplayQuantity @item.DisplayMeasurement
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 align-top text-center">
                                        <input type="checkbox"
                                               name="Items[@i].Include"
                                               value="true"
                                               checked
                                               class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" />
                                    </td>
                                </tr>

                                @* Hidden inputs that will populate AddToCartVM.Items[i] *@
                                <input type="hidden" name="Items[@i].Name" value="@item.Name" />
                                <input type="hidden" name="Items[@i].Upc" value="@item.Upc" />
                                <input type="hidden" name="Items[@i].Quantity" value="@item.Quantity" />
                                <input type="hidden" name="Items[@i].Modality" value="PICKUP" />
                                <input type="hidden" name="Items[@i].Measurement" value="@item.Measurement" />
                            }
                        </tbody>
                    </table>
                </div>

                <div class="flex justify-end gap-3 pt-3">
                    <button type="button"
                            id="add-to-list-button"
                            class="inline-flex items-center justify-center px-5 py-2.5 rounded-full text-sm font-semibold bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 transition">
                        Add to Shopping List
                    </button>
                    <button type="submit"
                            id="add-to-kroger-button"
                            class="inline-flex items-center justify-center px-5 py-2.5 rounded-full text-sm font-semibold bg-green-600 text-white hover:bg-green-700 transition">
                        Add to Kroger Cart
                    </button>
                </div>
            </form>
        }
    </section>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('add-to-kroger-form');
        if (!form) return;

        var krogerBtn = document.getElementById('add-to-kroger-button');
        var listBtn = document.getElementById('add-to-list-button');

        var originalAction = form.action;

        if (krogerBtn) {
            form.addEventListener('submit', function () {
                krogerBtn.disabled = true;
                krogerBtn.classList.add('opacity-70', 'cursor-not-allowed');
                krogerBtn.textContent = 'Adding to Kroger...';
            });
        }

        if (listBtn) {
            listBtn.addEventListener('click', function () {
                form.action = '@Url.Action("CreateFromMealPlan", "ShoppingList")';
                listBtn.disabled = true;
                listBtn.classList.add('opacity-70', 'cursor-not-allowed');
                listBtn.textContent = 'Creating list...';
                form.submit();
            });
        }
    });
</script>