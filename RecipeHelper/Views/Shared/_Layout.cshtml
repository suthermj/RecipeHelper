<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - RecipeHelper</title>

    <!-- App styles -->
    <link rel="stylesheet" href="/css/output.css" asp-append-version="true" />

    <!-- PWA / iOS home screen support -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Cooking Helper" />
    <meta name="theme-color" content="#7F1D1D" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" asp-append-version="true" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
</head>

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<body class="min-h-screen flex flex-col">

    <!-- Top App Bar -->
    <header class="bg-red-900 sticky top-0 z-50 safe-top">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <a asp-controller="Recipe" asp-action="Recipe" class="text-lg font-semibold text-white">
                Cooking Helper
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 py-3 pb-24">

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
                <span class="font-semibold">Success:</span> @success
            </div>
        }

        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
                <span class="font-semibold">Oops:</span> @error
            </div>
        }

        @RenderBody()
    </main>

    <!-- Bottom Tab Bar -->
    <nav class="fixed bottom-0 inset-x-0 z-50 bg-white border-t border-gray-200 safe-bottom">
        <div class="max-w-7xl mx-auto flex justify-around items-center h-14">
            <!-- Recipes -->
            <a asp-controller="Recipe" asp-action="Recipe"
               class="flex flex-col items-center gap-0.5 px-3 py-1 @(controller == "Recipe" ? "text-red-800" : "text-gray-400")">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
                <span class="text-[0.6rem] font-medium">Recipes</span>
            </a>

            <!-- Meal Plan -->
            <a asp-controller="Dinner" asp-action="SelectWeeklyRecipes"
               class="flex flex-col items-center gap-0.5 px-3 py-1 @(controller == "Dinner" ? "text-red-800" : "text-gray-400")">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
                <span class="text-[0.6rem] font-medium">Meal Plan</span>
            </a>

            <!-- Products -->
            <a asp-controller="Product" asp-action="Products"
               class="flex flex-col items-center gap-0.5 px-3 py-1 @(controller == "Product" ? "text-red-800" : "text-gray-400")">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
                <span class="text-[0.6rem] font-medium">Products</span>
            </a>

            <!-- Lists -->
            <a asp-controller="ShoppingList" asp-action="Index"
               class="flex flex-col items-center gap-0.5 px-3 py-1 @(controller == "ShoppingList" ? "text-red-800" : "text-gray-400")">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                </svg>
                <span class="text-[0.6rem] font-medium">Lists</span>
            </a>
        </div>
    </nav>

    <!-- Loading overlay (shown on form submit via .loading-form class) -->
    <div id="loadingOverlay" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/40">
        <div class="bg-white rounded-2xl shadow-xl px-8 py-6 flex flex-col items-center gap-3">
            <svg class="animate-spin h-8 w-8 text-red-800" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span id="loadingText" class="text-sm font-medium text-gray-700">Loading...</span>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
