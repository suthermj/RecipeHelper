@using RecipeHelper.Models.Kroger
@model AddToCartPreviewVM

@{
    ViewData["Title"]    = "Add to Cart";
    ViewData["NavTitle"] = "Add to Cart";
    ViewData["BackLink"] = Url.Action("ReviewDinnerSelections", "Dinner");
    ViewData["BackLabel"] = "Ingredients";
    var totalItems = Model.Items.Sum(i => i.QuantityToAdd);
}

<div class="pt-2 pb-32">

    @if (!Model.Items.Any())
    {
        <div class="mx-4 ios-card p-6 text-center">
            <p class="text-[15px]" style="color: var(--ios-label-2);">No items to add. Go back and select your recipes.</p>
        </div>
    }
    else
    {
        <form asp-action="BeginAddToCart" asp-controller="Cart" method="post" id="cartForm"
              class="loading-form" data-loading-text="Adding items to Kroger cart...">
            @Html.AntiForgeryToken()

            <!-- Select all -->
            <div class="ios-group mx-4 mb-4">
                <label class="ios-cell cursor-pointer select-none" style="border-bottom: 0.5px solid var(--ios-separator);">
                    <input type="checkbox" id="select-all" checked
                           class="h-5 w-5 rounded-full" style="accent-color: var(--ios-red);" />
                    <span class="flex-1 text-[15px] font-semibold" style="color: var(--ios-label);">Select all</span>
                    <span class="text-[13px]" style="color: var(--ios-label-2);">@totalItems item@(totalItems == 1 ? "" : "s")</span>
                </label>
            </div>

            <!-- Cart items -->
            <div class="ios-group">
                @for (var i = 0; i < Model.Items.Count; i++)
                {
                    var item = Model.Items[i];
                    <div class="ios-cell gap-3" style="border-bottom: 0.5px solid var(--ios-separator); align-items: flex-start; padding-top: 12px; padding-bottom: 12px;">

                        <div class="pt-0.5 shrink-0">
                            <input type="checkbox"
                                   class="row-include h-5 w-5 rounded-full"
                                   style="accent-color: var(--ios-red);"
                                   name="Items[@i].Include"
                                   value="true"
                                   checked />
                            <input type="hidden" name="Items[@i].Include" value="false" />
                            <input type="hidden" name="Items[@i].Upc" value="@item.Upc" />
                        </div>

                        <div class="h-14 w-14 flex-shrink-0 overflow-hidden rounded-xl" style="background: var(--ios-fill);">
                            <img src="https://www.kroger.com/product/images/medium/front/@item.Upc"
                                 alt="@item.Name"
                                 class="h-full w-full object-cover" />
                        </div>

                        <div class="flex-1 min-w-0 space-y-1">
                            <p class="text-[15px] font-semibold leading-snug" style="color: var(--ios-label);">@item.Name</p>
                            @if (!string.IsNullOrWhiteSpace(item.Brand))
                            {
                                <p class="text-[13px]" style="color: var(--ios-label-2);">@item.Brand</p>
                            }
                            <div class="flex flex-wrap items-center gap-2">
                                @if (!string.IsNullOrWhiteSpace(item.Size))
                                { <span class="text-[12px]" style="color: var(--ios-label-2);">@item.Size</span> }
                                @if (item.OnSale && item.PromoPrice > 0)
                                {
                                    <span class="text-[13px] font-semibold" style="color: var(--ios-label);">@item.PromoPrice.ToString("C")</span>
                                    <span class="text-[12px] line-through" style="color: var(--ios-label-2);">@item.RegularPrice.ToString("C")</span>
                                    <span class="ios-badge" style="background: #FFF0F0; color: var(--ios-red);">Sale</span>
                                }
                                else if (item.RegularPrice > 0)
                                {
                                    <span class="text-[13px] font-semibold" style="color: var(--ios-label);">@item.RegularPrice.ToString("C")</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.StockLevel))
                            {
                                <span class="inline-flex rounded-full px-2 py-0.5 text-[11px] font-medium @GetStockLevelBadgeClasses(item.StockLevel)">
                                    @item.StockLevel
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.OriginalIngredient))
                            {
                                <p class="text-[11px]" style="color: var(--ios-label-2);">Needed: @item.OriginalIngredient</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.ConversionNote))
                            {
                                <p class="text-[11px]" style="color: #FF9500;">&#9888; @item.ConversionNote</p>
                            }
                            <div class="flex items-center gap-2 pt-1">
                                <label class="text-[12px]" style="color: var(--ios-label-2);">Qty</label>
                                <input type="number"
                                       name="Items[@i].QuantityToAdd"
                                       value="@item.QuantityToAdd"
                                       min="1"
                                       class="field-input w-16 text-right py-1" style="font-size: 14px;" />
                            </div>
                        </div>
                    </div>
                }
            </div>
        </form>
    }
</div>

<!-- Fixed bottom action bar -->
@if (Model.Items.Any())
{
    <div class="fixed inset-x-0 z-30 px-4 py-3"
         style="bottom: calc(49px + env(safe-area-inset-bottom));
                background: rgba(249,249,249,0.94);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-top: 0.5px solid var(--ios-separator);">
        <button type="submit" form="cartForm" class="btn-primary w-full">
            Add to Kroger Cart
        </button>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var selectAll = document.getElementById('select-all');
            if (!selectAll) return;

            selectAll.addEventListener('change', function () {
                document.querySelectorAll('.row-include').forEach(function (cb) {
                    cb.checked = selectAll.checked;
                });
            });
        });
    </script>
}

@functions {
    public string GetStockLevelBadgeClasses(string level)
    {
        level = level?.ToUpperInvariant() ?? "";

        return level switch
        {
            "HIGH" => "bg-green-50 text-green-700 border border-green-200",
            "MEDIUM" => "bg-yellow-50 text-yellow-700 border border-yellow-300",
            "LOW" => "bg-orange-50 text-orange-700 border border-orange-300",
            "OUT_OF_STOCK" or "NONE" or "TEMPORARILY_OUT_OF_STOCK" => "bg-red-50 text-red-700 border border-red-300",
            _ => "bg-gray-100 text-gray-700 border border-gray-200"
        };
    }
}
