@{
    ViewData["Title"] = "Recipes";
    ViewData["NavTitle"] = "";
}

@model List<ViewRecipeVM>

@section TabBarCenterAction {
    <button type="button"
            id="recipeQuickAddButton"
            class="ios-tab-plus-btn"
            aria-label="Add recipe options"
            aria-haspopup="dialog"
            aria-expanded="false">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 5.25v13.5M5.25 12h13.5" />
        </svg>
    </button>
}

<div class="pt-2 pb-4">

    <!-- Large title -->
    <div class="px-4 pb-3">
        <h1 class="ios-large-title">Recipes</h1>
    </div>

    @if (Model == null || !Model.Any())
    {
        <!-- Empty state -->
        <div class="mx-4 rounded-2xl p-10 text-center" style="background: var(--ios-surface); box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
            <svg class="mx-auto h-14 w-14 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="1" style="color: var(--ios-label-3);">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
            <h2 class="text-[17px] font-semibold mb-1" style="color: var(--ios-label);">No recipes yet</h2>
            <p class="text-[15px] mb-5" style="color: var(--ios-label-2);">
                Add or import a recipe to get started.
            </p>
            <a asp-controller="Recipe" asp-action="CreateEditRecipe" class="btn-primary">
                Add your first recipe
            </a>
            <p class="mt-4 text-[13px]" style="color: var(--ios-label-2);">
                or <a class="ios-btn-text-sm" asp-controller="Import" asp-action="ImportRecipe">import from a link</a>
            </p>
        </div>
    }
    else
    {
        <!-- Sticky search + filter bar -->
        <div class="sticky sticky-below-nav z-30 pb-2"
             style="background: rgba(242,242,247,0.94); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">

            <!-- Search row -->
            <div class="px-4 pt-2 pb-2">
                <div class="ios-search-wrap">
                    <svg class="ios-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                    <input type="text"
                           id="recipeSearch"
                           placeholder="Search recipes…"
                           autocomplete="off"
                           class="ios-search-input" />
                </div>
            </div>

            <!-- Category pills -->
            <div class="flex overflow-x-auto gap-2 px-4 pb-1 hide-scrollbar">
                <button type="button" data-category=""
                        class="category-filter-btn ios-pill active">
                    All
                </button>
                @foreach (var cat in new[] { "Dinner", "Lunch", "Breakfast", "Side", "Dessert", "Snack", "Appetizer" })
                {
                    <button type="button" data-category="@cat"
                            class="category-filter-btn ios-pill">
                        @cat
                    </button>
                }
            </div>
        </div>

        <!-- Recipe count -->
        <p class="px-4 pt-3 pb-1 text-[13px]" style="color: var(--ios-label-2);">
            @Model.Count recipe@(Model.Count == 1 ? "" : "s")
        </p>

        <!-- Recipe grid -->
        <div id="recipeGrid" class="grid grid-cols-2 gap-3 px-4 sm:grid-cols-3 lg:grid-cols-4">
            @foreach (var recipe in Model)
            {
                <a asp-controller="Recipe"
                   asp-action="ViewRecipe"
                   asp-route-id="@recipe.Id"
                   data-recipe-name="@recipe.RecipeName"
                   data-category="@recipe.DinnerCategory"
                   class="recipe-card ios-card flex flex-col overflow-hidden active:opacity-75 transition-opacity"
                   style="text-decoration: none;">

                    <div class="w-full aspect-[4/3] overflow-hidden" style="background: var(--ios-fill);">
                        <img src="@(string.IsNullOrWhiteSpace(recipe.ImageUri)
                                        ? Url.Content("https://recipestoragep.blob.core.windows.net/recipe-images/default-recipe-image.webp")
                                        : recipe.ImageUri)"
                             alt="@recipe.RecipeName"
                             loading="lazy"
                             decoding="async"
                             class="w-full h-full object-cover" />
                    </div>

                    <div class="p-2.5">
                        <p class="text-[13px] font-semibold leading-snug line-clamp-2" style="color: var(--ios-label);">
                            @recipe.RecipeName
                        </p>
                        @if (!string.IsNullOrEmpty(recipe.DinnerCategory))
                        {
                            <p class="text-[11px] mt-0.5" style="color: var(--ios-label-2);">@recipe.DinnerCategory</p>
                        }
                    </div>
                </a>
            }
        </div>

        <!-- Empty search state -->
        <div id="emptyResults" class="hidden text-center py-14">
            <p class="text-[15px]" style="color: var(--ios-label-2);">No recipes match your search.</p>
            <button id="clearFilters" type="button" class="ios-btn-text-sm mt-2">
                Clear filters
            </button>
        </div>
    }
</div>

<div id="recipeQuickAddSheet"
     class="ios-action-sheet-backdrop hidden"
     aria-hidden="true">
    <div class="ios-action-sheet" role="dialog" aria-modal="true" aria-labelledby="recipeQuickAddTitle">
        <div class="flex justify-center pt-2.5 pb-1 sm:hidden">
            <div class="w-9 h-1 rounded-full" style="background: var(--ios-separator);"></div>
        </div>
        <div class="px-4 pt-2 pb-3 text-center">
            <p id="recipeQuickAddTitle" class="text-[17px] font-semibold" style="color: var(--ios-label);">Add a recipe</p>
            <p class="mt-1 text-[13px]" style="color: var(--ios-label-2);">Choose how you want to start.</p>
        </div>
        <div class="px-4 pb-4 space-y-2">
            <a asp-controller="Recipe"
               asp-action="CreateEditRecipe"
               class="ios-action-sheet-option">
                <span class="font-semibold" style="color: var(--ios-label);">Create manually</span>
                <span style="color: var(--ios-label-2);">Start with a blank recipe.</span>
            </a>
            <a asp-controller="Import"
               asp-action="ImportRecipe"
               class="ios-action-sheet-option">
                <span class="font-semibold" style="color: var(--ios-label);">Import from link</span>
                <span style="color: var(--ios-label-2);">Paste a recipe URL to pull it in.</span>
            </a>
            <button type="button"
                    class="ios-action-sheet-option ios-action-sheet-option-disabled"
                    disabled>
                <span class="font-semibold" style="color: var(--ios-label-2);">Import from photo</span>
                <span style="color: var(--ios-label-2);">Coming soon.</span>
            </button>
            <button type="button" id="recipeQuickAddCancel" class="btn-secondary w-full">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const quickAddButton = document.getElementById('recipeQuickAddButton');
        const quickAddSheet = document.getElementById('recipeQuickAddSheet');
        const quickAddCancel = document.getElementById('recipeQuickAddCancel');
        let quickAddCloseTimer;
        let quickAddOpenRaf;

        function setQuickAddOpen(open) {
            if (!quickAddSheet || !quickAddButton) return;
            window.clearTimeout(quickAddCloseTimer);
            window.cancelAnimationFrame(quickAddOpenRaf);

            if (open) {
                quickAddSheet.classList.remove('hidden');
                quickAddSheet.classList.add('flex');
                quickAddSheet.setAttribute('aria-hidden', 'false');
                quickAddButton.setAttribute('aria-expanded', 'true');
                document.body.classList.add('overflow-hidden');
                // Force the pre-open state to paint before enabling the animated state.
                void quickAddSheet.offsetHeight;
                quickAddOpenRaf = window.requestAnimationFrame(function () {
                    quickAddOpenRaf = window.requestAnimationFrame(function () {
                        quickAddSheet.classList.add('is-open');
                    });
                });
                return;
            }

            quickAddSheet.classList.remove('is-open');
            quickAddSheet.setAttribute('aria-hidden', 'true');
            quickAddButton.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('overflow-hidden');
            quickAddCloseTimer = window.setTimeout(function () {
                quickAddSheet.classList.add('hidden');
                quickAddSheet.classList.remove('flex');
            }, 260);
        }

        quickAddButton?.addEventListener('click', function () {
            const isOpen = quickAddSheet?.classList.contains('flex');
            setQuickAddOpen(!isOpen);
        });

        quickAddCancel?.addEventListener('click', function () {
            setQuickAddOpen(false);
        });

        quickAddSheet?.addEventListener('click', function (e) {
            if (e.target === quickAddSheet) setQuickAddOpen(false);
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') setQuickAddOpen(false);
        });

        const input      = document.getElementById('recipeSearch');
        const filterBtns = document.querySelectorAll('.category-filter-btn');
        const emptyEl    = document.getElementById('emptyResults');
        const clearBtn   = document.getElementById('clearFilters');
        let activeCategory = '';

        function filterCards() {
            const term = input ? input.value.toLowerCase().trim() : '';
            let visible = 0;
            document.querySelectorAll('.recipe-card').forEach(card => {
                const name = (card.dataset.recipeName || '').toLowerCase();
                const cat  = card.dataset.category || '';
                const show = name.includes(term) && (activeCategory === '' || cat === activeCategory);
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
        }

        if (input) input.addEventListener('input', filterCards);

        filterBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                activeCategory = this.dataset.category;
                filterBtns.forEach(b => b.classList.toggle('active', b.dataset.category === activeCategory));
                this.scrollIntoView({ inline: 'center', block: 'nearest' });
                filterCards();
            });
        });

        if (clearBtn) {
            clearBtn.addEventListener('click', function () {
                if (input) input.value = '';
                activeCategory = '';
                filterBtns.forEach(b => b.classList.toggle('active', b.dataset.category === ''));
                document.querySelector('.category-filter-btn[data-category=""]')
                    ?.scrollIntoView({ inline: 'center', block: 'nearest' });
                filterCards();
            });
        }
    })();
</script>
}
