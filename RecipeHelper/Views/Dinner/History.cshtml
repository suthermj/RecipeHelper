@using RecipeHelper.Models.Dinner
@model List<MealPlan>

@{
    ViewData["Title"] = "Meal Plan History";
    string DefaultImg = "https://recipestoragep.blob.core.windows.net/recipe-images/default-recipe-image.webp";
}

<div class="max-w-xl mx-auto px-4 py-6 space-y-5">

    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold tracking-tight">Meal Plan History</h1>
        <a asp-action="PlanWeek"
           class="inline-flex items-center justify-center px-4 py-2 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">
            Plan this week
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center gap-3 py-20 text-center">
            <p class="font-semibold text-gray-900">No saved plans yet</p>
            <p class="text-sm text-gray-500">Save your first weekly plan to see it here.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var plan in Model)
            {
                var weekEnd = plan.WeekStartDate.AddDays(6);
                var thumbs = plan.Entries
                    .OrderBy(e => e.DayOfWeek)
                    .Select(e => e.Recipe?.ImageUri is { Length: > 0 } u ? u : DefaultImg)
                    .ToList();

                <a asp-action="ViewPlan" asp-route-id="@plan.Id"
                   class="block bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-red-300 transition overflow-hidden">
                    <div class="px-4 pt-3 pb-2">
                        <p class="text-sm font-semibold text-gray-900">
                            @plan.WeekStartDate.ToString("MMM d") – @weekEnd.ToString("MMM d, yyyy")
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">@plan.Entries.Count recipe(s)</p>
                    </div>
                    @if (thumbs.Any())
                    {
                        <div class="flex gap-1 px-4 pb-3 overflow-x-auto">
                            @foreach (var img in thumbs)
                            {
                                <div class="w-12 h-12 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                                    <img src="@img" alt="" class="w-full h-full object-cover" />
                                </div>
                            }
                        </div>
                    }
                </a>
            }
        </div>
    }

</div>
