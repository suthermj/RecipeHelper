@using RecipeHelper.Models.Dinner
@using RecipeHelper.Services
@model MealPlan?

@{
    ViewData["Title"] = "Meal Plan";

    var weekStart = MealPlanService.GetWeekStart(DateTime.UtcNow);
    var weekEnd = weekStart.AddDays(6);
    string WeekRange(DateTime s, DateTime e) =>
        s.Month == e.Month
            ? $"{s:MMM d}–{e:d}"
            : $"{s:MMM d} – {e:MMM d}";

    string[] dayNames = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    string DefaultImg = "https://recipestoragep.blob.core.windows.net/recipe-images/default-recipe-image.webp";
}

<div class="max-w-xl mx-auto px-4 py-6 space-y-6">

    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight">Meal Plan</h1>
            <p class="text-sm text-gray-500 mt-0.5">@WeekRange(weekStart, weekEnd)</p>
        </div>
        @if (Model != null)
        {
            <a asp-action="PlanWeek" asp-route-id="@Model.Id"
               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition">
                Edit
            </a>
        }
    </div>

    @if (Model == null)
    {
        <!-- Empty state -->
        <div class="flex flex-col items-center justify-center gap-4 py-20 text-center">
            <div class="h-16 w-16 rounded-full bg-red-50 flex items-center justify-center">
                <svg class="h-8 w-8 text-red-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
            </div>
            <div>
                <p class="font-semibold text-gray-900">No plan for this week</p>
                <p class="text-sm text-gray-500 mt-1">Assign recipes to each day to get started.</p>
            </div>
            <a asp-action="PlanWeek"
               class="inline-flex items-center justify-center px-6 py-2.5 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">
                Plan this week
            </a>
        </div>
    }
    else
    {
        <!-- 7 day cards -->
        <div class="space-y-3">
            @for (int d = 0; d < 7; d++)
            {
                var entry = Model.Entries.FirstOrDefault(e => e.DayOfWeek == d);
                <div class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                    <div class="w-20 h-16 shrink-0 bg-gray-100 overflow-hidden">
                        <img src="@(entry?.Recipe?.ImageUri is { Length: > 0 } u ? u : DefaultImg)"
                             alt="@(entry?.Recipe?.Name ?? "No recipe")"
                             class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 min-w-0 pr-3">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">@dayNames[d]</p>
                        <p class="text-sm font-medium text-gray-900 truncate mt-0.5">
                            @(entry?.Recipe?.Name ?? "—")
                        </p>
                    </div>
                </div>
            }
        </div>

        <!-- Review ingredients -->
        @{
            var recipeIds = Model.Entries.Select(e => e.RecipeId).Distinct().ToList();
        }
        @if (recipeIds.Any())
        {
            <form asp-action="SubmitDinnerSelections" method="post">
                @Html.AntiForgeryToken()
                @foreach (var rid in recipeIds)
                {
                    <input type="hidden" name="selectedRecipes" value="@rid" />
                }
                <button type="submit"
                        class="w-full inline-flex items-center justify-center px-5 py-3 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">
                    Review ingredients
                </button>
            </form>
        }
    }

    <!-- History link -->
    <div class="flex justify-center pt-2">
        <a asp-action="History" class="text-sm text-gray-500 hover:text-gray-700 underline underline-offset-2">
            View history
        </a>
    </div>

</div>
