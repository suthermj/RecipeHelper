@model RecipeHelper.ViewModels.ImportRecipePageVM
@{
    ViewData["Title"]    = "Import Recipe";
    ViewData["NavTitle"] = "Import Recipe";
    ViewData["BackLink"] = Url.Action("Recipe", "Recipe");
    ViewData["BackLabel"] = "Recipes";
    var hasResult = Model?.Preview != null;
}

<div class="pt-2 pb-6">

    <!-- URL import form -->
    <div class="px-4 pb-3">
        <form id="importForm" asp-action="ImportRecipe" method="get" novalidate>
            <div class="flex gap-2 items-center">
                <div class="ios-search-wrap flex-1">
                    <svg class="ios-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                    </svg>
                    <input asp-for="Url" type="url" required
                           placeholder="Paste a recipe URL…"
                           class="ios-search-input" />
                </div>
                <button id="importBtn" type="submit" class="ios-inline-action">
                    <svg id="importBtnSpinner" class="hidden animate-spin h-4 w-4 inline" viewBox="0 0 24 24" fill="none">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4A4 4 0 004 12z"></path>
                    </svg>
                    <span id="importBtnText">Import</span>
                </button>
            </div>
        </form>
    </div>

    <!-- Clipboard paste banner -->
    <div id="clipboardBanner" class="hidden mx-4 mb-3">
        <div class="ios-cell rounded-xl gap-3" style="background: var(--ios-fill);">
            <span class="flex-1 text-[14px]" style="color: var(--ios-label-2);">Have a recipe URL copied?</span>
            <button type="button" class="clip-paste-btn ios-inline-action">Paste</button>
            <button type="button" class="clip-dismiss-btn ios-btn-text-sm" style="color: var(--ios-label-2);">&times;</button>
        </div>
    </div>

    <!-- Loading overlay -->
    <div id="loadingOverlay" class="hidden fixed inset-0 z-[100] flex items-center justify-center" style="background: rgba(0,0,0,0.3);">
        <div class="flex items-center gap-3 px-5 py-4 rounded-2xl" style="background: var(--ios-surface);">
            <svg class="animate-spin h-5 w-5" style="color: var(--ios-red);" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4A4 4 0 004 12z"></path>
            </svg>
            <span class="text-[15px]" style="color: var(--ios-label);">Importing recipe…</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ViewBag.Error as string))
    {
        <div class="mx-4 mb-3 rounded-2xl px-4 py-3 text-[14px]" style="background: #FFF0F0; color: var(--ios-red);">
            @ViewBag.Error
        </div>
    }

    @if (hasResult)
    {
        var img = string.IsNullOrWhiteSpace(Model.Preview!.Image)
            ? Url.Content("~/images/default-recipe.png")
            : Model.Preview.Image;

        <div class="px-4 space-y-4">

            <!-- Hero image + title -->
            <div class="ios-card overflow-hidden">
                <img src="@img" alt="@Model.Preview.Title"
                     class="w-full object-cover" style="aspect-ratio: 16/9; max-height: 220px;" />
                <div class="p-4 space-y-2">
                    <h2 class="text-[20px] font-bold" style="color: var(--ios-label);">@Model.Preview.Title</h2>
                    <div class="flex flex-wrap gap-2">
                        @if (Model.Preview.ReadyInMinutes is not null)
                        { <span class="ios-badge" style="background: var(--ios-fill); color: var(--ios-label-2);">@Model.Preview.ReadyInMinutes min</span> }
                        @if (Model.Preview.Servings is not null)
                        { <span class="ios-badge" style="background: var(--ios-fill); color: var(--ios-label-2);">@Model.Preview.Servings servings</span> }
                        @if (Model.Preview.Vegetarian)
                        { <span class="ios-badge" style="background: #E8F8E8; color: #1A6B1A;">Vegetarian</span> }
                        @if (Model.Preview.Vegan)
                        { <span class="ios-badge" style="background: #E2F5E2; color: #145C14;">Vegan</span> }
                        @if (Model.Preview.GlutenFree)
                        { <span class="ios-badge" style="background: #FFF8E1; color: #7A5900;">Gluten-free</span> }
                        @if (Model.Preview.DairyFree)
                        { <span class="ios-badge" style="background: #E3F0FF; color: #1A4A7A;">Dairy-free</span> }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Preview.SourceUrl))
                    {
                        <a href="@Model.Preview.SourceUrl" target="_blank" class="ios-btn-text-sm" style="text-decoration: underline;">View source</a>
                    }
                </div>
            </div>

            <!-- Ingredients -->
            @if (Model.Preview.Ingredients?.Count > 0)
            {
                <div>
                    <p class="ios-section-hdr" style="padding-left: 0;">Ingredients</p>
                    <div class="ios-group">
                        @foreach (var ing in Model.Preview.Ingredients)
                        {
                            <div class="ios-cell">
                                <span class="text-[15px]" style="color: var(--ios-label);">
                                    @if (!string.IsNullOrWhiteSpace(ing.DisplayAmount))
                                    {
                                        <span class="font-semibold">@ing.DisplayAmount</span>
                                        @(" " + ing.Name)
                                    }
                                    else { @ing.Name }
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Instructions -->
            @if (Model.Preview.Steps?.Count > 0)
            {
                <div>
                    <p class="ios-section-hdr" style="padding-left: 0;">Instructions</p>
                    <div class="ios-group">
                        @for (int i = 0; i < Model.Preview.Steps.Count; i++)
                        {
                            <div class="ios-cell gap-3">
                                <span class="h-6 w-6 rounded-full flex items-center justify-center text-[12px] font-bold text-white shrink-0"
                                      style="background: var(--ios-red);">@(i + 1)</span>
                                <span class="text-[15px]" style="color: var(--ios-label);">@Model.Preview.Steps[i]</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Review & Save -->
            <form asp-action="GetImportedRecipePreview" method="post" class="loading-form" data-loading-text="Preparing recipe preview...">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Title" value="@Model.Preview.Title" />
                <input type="hidden" name="Image" value="@Model.Preview.Image" />
                <input type="hidden" name="SourceUrl" value="@Model.Preview.SourceUrl" />
                @for (var i = 0; i < Model.Preview.Ingredients.Count; i++)
                {
                    var ing = Model.Preview.Ingredients[i];
                    <input type="hidden" name="Ingredients[@i].Name" value="@ing.Name" />
                    <input type="hidden" name="Ingredients[@i].CleanName" value="@ing.CleanName" />
                    <input type="hidden" name="Ingredients[@i].Amount" value="@(ing.Amount ?? 0)" />
                    <input type="hidden" name="Ingredients[@i].Unit" value="@ing.Unit" />
                }
                @if (Model.Preview.Steps != null)
                {
                    @for (var i = 0; i < Model.Preview.Steps.Count; i++)
                    {
                        <input type="hidden" name="Steps[@i]" value="@Model.Preview.Steps[i]" />
                    }
                }
                <button type="submit" class="btn-primary w-full">Review &amp; Save</button>
            </form>
        </div>
    }
    else if (string.IsNullOrWhiteSpace(ViewBag.Error as string))
    {
        <div class="mx-4 ios-card p-8 text-center">
            <svg class="mx-auto h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"
                 style="color: var(--ios-label-2);">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            <p class="text-[15px] font-semibold mb-1" style="color: var(--ios-label);">Paste a recipe URL</p>
            <p class="text-[13px]" style="color: var(--ios-label-2);">Fetch ingredients and steps, then review and save.</p>
        </div>
    }
</div>

<script>
    (function () {
        const form    = document.getElementById('importForm');
        const btn     = document.getElementById('importBtn');
        const spinner = document.getElementById('importBtnSpinner');
        const btnText = document.getElementById('importBtnText');
        const overlay = document.getElementById('loadingOverlay');
        const urlInput = form.querySelector('input[name="Url"]');

        const clipBanner = document.getElementById('clipboardBanner');
        if (clipBanner && !urlInput.value.trim()) {
            clipBanner.querySelector('.clip-paste-btn').addEventListener('click', async function () {
                try {
                    const text = await navigator.clipboard.readText();
                    if (text && /^https?:\/\//i.test(text.trim())) {
                        urlInput.value = text.trim();
                        urlInput.focus();
                    }
                } catch { }
                clipBanner.remove();
            });
            clipBanner.querySelector('.clip-dismiss-btn').addEventListener('click', function () {
                clipBanner.remove();
            });
            clipBanner.classList.remove('hidden');
        }

        form.addEventListener('submit', function () {
            if (!form.checkValidity()) return;
            btn.disabled = true;
            urlInput.readOnly = true;
            spinner.classList.remove('hidden');
            btnText.textContent = 'Importing…';
            overlay.classList.remove('hidden');
        });
    })();
</script>
