@model RecipeHelper.Models.Settings.SettingsVM

@{
    ViewData["Title"]    = "Settings";
    ViewData["NavTitle"] = "Settings";
}

<div class="pt-2 pb-6">

    <!-- Catalog -->
    <p class="ios-section-hdr">Catalog</p>
    <div class="ios-group">
        <a asp-controller="Product" asp-action="Products" class="ios-cell justify-between" style="text-decoration:none;">
            <div class="min-w-0">
                <p class="text-[16px] font-semibold" style="color: var(--ios-label);">Products</p>
                <p class="text-[13px]" style="color: var(--ios-label-2);">Browse and manage your saved products.</p>
            </div>
            <svg class="h-4 w-4 shrink-0 ios-disclosure" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
        </a>
    </div>

    <!-- Current Store -->
    <p class="ios-section-hdr">Kroger Store</p>
    <div class="ios-group">
        <div class="ios-cell justify-between">
            <div class="min-w-0">
                <p class="text-[16px] font-semibold" style="color: var(--ios-label);">@Model.CurrentStoreName</p>
                <p class="text-[13px]" style="color: var(--ios-label-2);">ID: @Model.CurrentLocationId</p>
            </div>
            <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"
                 style="color: #34C759;">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
            </svg>
        </div>
    </div>

    <!-- Change Store -->
    <p class="ios-section-hdr">Change Store</p>
    <div class="ios-group">
        <div class="ios-cell flex-col items-stretch gap-3 py-4" style="align-items: stretch;">
            <div class="flex items-center gap-2">
                <div class="ios-search-wrap flex-1">
                    <svg class="ios-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    <input id="zipInput" type="text" placeholder="ZIP code…"
                           inputmode="numeric" maxlength="5"
                           class="ios-search-input" />
                </div>
                <button id="searchBtn" type="button" class="ios-inline-action">Search</button>
            </div>
        </div>

        <div class="ios-cell" style="border-bottom: none;">
            <button id="locationBtn" class="ios-inline-action flex items-center gap-2">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                Use my location
            </button>
        </div>
    </div>

    <p id="locationError" class="text-[13px] px-4 mt-2 hidden" style="color: var(--ios-red);">
        Unable to get your location. Please enter a ZIP code.
    </p>

    <!-- Search results -->
    <div id="searchResults" class="hidden mt-2 space-y-0 ios-group"></div>
    <p id="searchEmpty" class="text-[14px] px-4 mt-2 hidden" style="color: var(--ios-label-2);">No stores found for that ZIP code.</p>
    <p id="searchError"  class="text-[14px] px-4 mt-2 hidden" style="color: var(--ios-red);">Something went wrong. Please try again.</p>

</div>

<!-- Hidden form for store selection POST -->
<form id="selectStoreForm" asp-action="SelectStore" method="post" class="hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" name="locationId" id="selectLocationId" />
    <input type="hidden" name="storeName"  id="selectStoreName"  />
    <input type="hidden" name="latitude"   id="selectLatitude"   />
    <input type="hidden" name="longitude"  id="selectLongitude"  />
</form>

@section Scripts {
<script>
    const searchBtn        = document.getElementById('searchBtn');
    const zipInput         = document.getElementById('zipInput');
    const locationBtn      = document.getElementById('locationBtn');
    const locationError    = document.getElementById('locationError');
    const resultsContainer = document.getElementById('searchResults');
    const emptyMsg         = document.getElementById('searchEmpty');
    const errorMsg         = document.getElementById('searchError');
    const selectForm       = document.getElementById('selectStoreForm');

    function resetResults() {
        resultsContainer.classList.add('hidden');
        resultsContainer.innerHTML = '';
        emptyMsg.classList.add('hidden');
        errorMsg.classList.add('hidden');
        locationError.classList.add('hidden');
    }

    function selectStore(locationId, storeName, latitude, longitude) {
        document.getElementById('selectLocationId').value = locationId;
        document.getElementById('selectStoreName').value  = storeName;
        document.getElementById('selectLatitude').value   = latitude  ?? '';
        document.getElementById('selectLongitude').value  = longitude ?? '';
        selectForm.submit();
    }

    function renderStores(stores) {
        if (stores.length === 0) { emptyMsg.classList.remove('hidden'); return; }
        stores.forEach(store => {
            const cell = document.createElement('div');
            cell.className = 'ios-cell justify-between';
            cell.style.borderBottom = '0.5px solid var(--ios-separator)';
            cell.innerHTML = `
                <div class="min-w-0 flex-1">
                    <p class="text-[15px] font-medium" style="color:var(--ios-label);">${store.name}</p>
                    <p class="text-[13px]" style="color:var(--ios-label-2);">${store.address}</p>
                    ${store.phone ? `<p class="text-[12px]" style="color:var(--ios-label-2);">${store.phone}</p>` : ''}
                </div>
                <button type="button" class="ios-btn-text-sm font-semibold shrink-0 ml-3 select-btn">Select</button>
            `;
            cell.querySelector('.select-btn').addEventListener('click', () =>
                selectStore(store.locationId, store.name, store.latitude, store.longitude));
            resultsContainer.appendChild(cell);
        });
        resultsContainer.classList.remove('hidden');
    }

    async function searchStores() {
        const zip = zipInput.value.trim();
        if (!zip || zip.length < 5) return;
        resetResults();
        searchBtn.disabled = true;
        searchBtn.textContent = 'Searching…';
        try {
            const res = await fetch(`/Settings/SearchStores?zipCode=${encodeURIComponent(zip)}`);
            if (!res.ok) throw new Error();
            renderStores(await res.json());
        } catch {
            errorMsg.classList.remove('hidden');
        } finally {
            searchBtn.disabled = false;
            searchBtn.textContent = 'Search';
        }
    }

    locationBtn.addEventListener('click', () => {
        if (!navigator.geolocation) { locationError.classList.remove('hidden'); return; }
        resetResults();
        locationBtn.textContent = 'Detecting…';
        locationBtn.disabled = true;
        navigator.geolocation.getCurrentPosition(
            async (pos) => {
                try {
                    const res = await fetch(`/Settings/SearchStoresByLocation?latitude=${pos.coords.latitude}&longitude=${pos.coords.longitude}`);
                    if (!res.ok) throw new Error();
                    renderStores(await res.json());
                } catch { errorMsg.classList.remove('hidden'); }
                finally { locationBtn.textContent = 'Use my location'; locationBtn.disabled = false; }
            },
            () => { locationError.classList.remove('hidden'); locationBtn.textContent = 'Use my location'; locationBtn.disabled = false; }
        );
    });

    searchBtn.addEventListener('click', searchStores);
    zipInput.addEventListener('keydown', e => { if (e.key === 'Enter') searchStores(); });
</script>
}
