@using RecipeHelper.Models.Dinner
@model PlanWeekVM

@{
    ViewData["Title"] = "Plan This Week";

    var weekEnd = Model.WeekStartDate.AddDays(6);
    string[] dayNames = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    string DefaultImg = "https://recipestoragep.blob.core.windows.net/recipe-images/default-recipe-image.webp";

    // Build a lookup for pre-filled recipe info
    var recipeLookup = Model.AllRecipes.ToDictionary(r => r.Id);
}

<div class="max-w-xl mx-auto px-4 py-6 space-y-5">

    <div>
        <h1 class="text-2xl font-semibold tracking-tight">Plan This Week</h1>
        <p class="text-sm text-gray-500 mt-0.5">
            @Model.WeekStartDate.ToString("MMM d") – @weekEnd.ToString("MMM d, yyyy")
        </p>
    </div>

    <form asp-action="SaveMealPlan" method="post" id="planForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="WeekStartDate" value="@Model.WeekStartDate.ToString("O")" />

        <div class="space-y-3" id="daySlots">
            @for (int d = 0; d < 7; d++)
            {
                var prefilledId = Model.DayRecipes.Length > d ? Model.DayRecipes[d] : null;
                var prefilledRecipe = prefilledId.HasValue && recipeLookup.TryGetValue(prefilledId.Value, out var r) ? r : null;

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden" data-day="@d">
                    <div class="px-4 py-2 bg-gray-50 border-b border-gray-100">
                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@dayNames[d]</p>
                    </div>

                    <div class="p-3">
                        <!-- Hidden input for this day's recipe -->
                        <input type="hidden"
                               name="DayRecipes[@d]"
                               id="dayInput_@d"
                               value="@(prefilledId?.ToString() ?? "")" />

                        <!-- Empty slot (shown when no recipe selected) -->
                        <button type="button"
                                class="pick-btn w-full flex items-center justify-center gap-2 py-3 rounded-lg border-2 border-dashed border-gray-200 text-sm text-gray-400 hover:border-red-300 hover:text-red-700 transition @(prefilledRecipe != null ? "hidden" : "")"
                                data-day="@d">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                            Pick a recipe
                        </button>

                        <!-- Selected recipe display (shown when recipe chosen) -->
                        <div class="selected-display flex items-center gap-3 @(prefilledRecipe == null ? "hidden" : "")"
                             id="selected_@d">
                            <div class="w-14 h-12 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                                <img src="@(prefilledRecipe?.ImageUri is { Length: > 0 } u ? u : DefaultImg)"
                                     alt=""
                                     class="w-full h-full object-cover selected-img" />
                            </div>
                            <p class="flex-1 text-sm font-medium text-gray-900 truncate selected-name">
                                @(prefilledRecipe?.RecipeName ?? "")
                            </p>
                            <button type="button"
                                    class="clear-btn shrink-0 p-1 rounded-full text-gray-400 hover:text-red-600 hover:bg-red-50 transition"
                                    data-day="@d"
                                    title="Remove">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <button type="submit"
                class="w-full mt-4 inline-flex items-center justify-center px-5 py-3 rounded-full text-sm font-semibold bg-red-800 text-white hover:bg-red-900 transition">
            Save plan
        </button>
    </form>

</div>

<!-- Recipe picker modal -->
<dialog id="recipePicker"
        class="w-full max-w-lg rounded-2xl shadow-2xl p-0 backdrop:bg-black/40 m-auto max-h-[85vh] flex flex-col">
    <div class="sticky top-0 bg-white z-10 px-4 pt-4 pb-3 border-b border-gray-100">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold text-gray-900">Pick a recipe</h2>
            <button type="button" id="closeModal"
                    class="p-1 rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <input type="text" id="recipeSearch"
               placeholder="Search recipes…"
               class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-700" />
    </div>

    <div id="recipeList" class="overflow-y-auto flex-1 p-3 grid grid-cols-2 gap-3">
        @foreach (var recipe in Model.AllRecipes)
        {
            <button type="button"
                    class="recipe-option flex flex-col overflow-hidden bg-white border border-gray-200 rounded-xl shadow-sm hover:border-red-400 transition text-left focus:outline-none focus:ring-2 focus:ring-red-600"
                    data-id="@recipe.Id"
                    data-name="@recipe.RecipeName"
                    data-img="@(string.IsNullOrWhiteSpace(recipe.ImageUri) ? DefaultImg : recipe.ImageUri)">
                <div class="w-full h-24 bg-gray-100 overflow-hidden">
                    <img src="@(string.IsNullOrWhiteSpace(recipe.ImageUri) ? DefaultImg : recipe.ImageUri)"
                         alt="@recipe.RecipeName"
                         class="w-full h-full object-cover" />
                </div>
                <div class="p-2">
                    <p class="text-xs font-semibold text-gray-900 line-clamp-2">@recipe.RecipeName</p>
                </div>
            </button>
        }
    </div>
</dialog>

<script>
    const dialog = document.getElementById('recipePicker');
    const recipeSearch = document.getElementById('recipeSearch');
    let activeDay = null;
    const defaultImg = '@DefaultImg';

    document.querySelectorAll('.pick-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            activeDay = parseInt(btn.dataset.day);
            recipeSearch.value = '';
            filterRecipes('');
            dialog.showModal();
            recipeSearch.focus();
        });
    });

    document.getElementById('closeModal').addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });

    recipeSearch.addEventListener('input', () => filterRecipes(recipeSearch.value.toLowerCase().trim()));

    function filterRecipes(term) {
        document.querySelectorAll('.recipe-option').forEach(card => {
            const match = !term || card.dataset.name.toLowerCase().includes(term);
            card.classList.toggle('hidden', !match);
        });
    }

    document.querySelectorAll('.recipe-option').forEach(card => {
        card.addEventListener('click', () => {
            if (activeDay === null) return;
            selectRecipe(activeDay, card.dataset.id, card.dataset.name, card.dataset.img);
            dialog.close();
        });
    });

    document.querySelectorAll('.clear-btn').forEach(btn => {
        btn.addEventListener('click', () => clearDay(parseInt(btn.dataset.day)));
    });

    function selectRecipe(day, id, name, img) {
        document.getElementById('dayInput_' + day).value = id;

        const slot = document.querySelector('[data-day="' + day + '"]');
        const pickBtn = slot.querySelector('.pick-btn');
        const display = document.getElementById('selected_' + day);

        display.querySelector('.selected-img').src = img || defaultImg;
        display.querySelector('.selected-name').textContent = name;

        pickBtn.classList.add('hidden');
        display.classList.remove('hidden');
    }

    function clearDay(day) {
        document.getElementById('dayInput_' + day).value = '';

        const slot = document.querySelector('[data-day="' + day + '"]');
        const pickBtn = slot.querySelector('.pick-btn');
        const display = document.getElementById('selected_' + day);

        pickBtn.classList.remove('hidden');
        display.classList.add('hidden');
    }
</script>
