@model CreateRecipeVM

@{
    ViewData["Title"] = "Create Recipe";

    if (Model.Ingredients == null)
        Model.Ingredients = new List<CreateRecipeIngredientVM>();

    if (!Model.Ingredients.Any())
        Model.Ingredients.Add(new CreateRecipeIngredientVM());
}

<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Create Recipe</h1>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>
    <span asp-validation-for="Title" class="text-red-600 text-sm"></span>
    <form asp-action="CreateRecipe" asp-controller="Recipe" method="post" enctype="multipart/form-data" class="space-y-8 loading-form" data-loading-text="Saving recipe...">
        @Html.AntiForgeryToken()

        <!-- Basic info -->
        <div class="bg-white rounded-2xl shadow p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                <input asp-for="Title"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring"
                       placeholder="e.g., Chicken Tacos" />
                <span asp-validation-for="Title" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Image (optional)</label>
                <input asp-for="ImageFile" type="file" accept="image/*"
                       class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gray-100 hover:file:bg-gray-200" />
                <span asp-validation-for="ImageFile" class="text-sm text-red-600"></span>
            </div>
        </div>

        <!-- Category -->
        <div class="bg-white rounded-2xl shadow p-6">
            <h2 class="text-lg font-semibold mb-3">Category</h2>
            <div class="flex flex-wrap gap-4">
                @foreach (var cat in new[] { "Dinner", "Lunch", "Breakfast", "Side", "Dessert", "Snack", "Appetizer" })
                {
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="radio" name="DinnerCategory" value="@cat"
                               class="border-gray-300" />
                        @cat
                    </label>
                }
            </div>
        </div>

        <!-- Ingredients -->
        <div class="bg-white rounded-2xl shadow p-4 sm:p-6">
            <h2 class="text-lg font-semibold mb-1">Ingredients</h2>
            <p class="text-sm text-gray-500 mb-3">
                Type each ingredient with its amount. Use the dropdown to mark a row as a section header.
            </p>

            <div id="ingredientsContainer" class="space-y-2">
                @{
                    string? cPrevSec = "__NONE__";
                    int cIdx = 0;
                }
                @for (int i = 0; i < Model.Ingredients.Count; i++)
                {
                    var ing = Model.Ingredients[i];
                    var emitHeader = false;
                    if (ing.Section != cPrevSec)
                    {
                        cPrevSec = ing.Section;
                        emitHeader = !string.IsNullOrEmpty(ing.Section);
                    }
                    var thisIdx = cIdx;
                    cIdx++;

                    if (emitHeader)
                    {
                        <div class="entry-row rounded-lg border border-gray-100 bg-gray-50 p-3 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:flex sm:items-center sm:gap-2" data-type="header">
                            <span class="drag-handle cursor-grab active:cursor-grabbing text-gray-400 hover:text-gray-600 shrink-0 select-none hidden sm:inline" title="Drag to reorder">&#x2630;</span>
                            <select class="entry-type hidden sm:inline rounded border border-gray-200 text-xs py-1.5 px-1 text-gray-500 bg-white shrink-0">
                                <option value="ingredient">Ingredient</option>
                                <option value="header" selected>Section</option>
                            </select>
                            <div class="entry-content sm:flex-1 sm:flex sm:items-center sm:gap-2">
                                <div class="flex items-center gap-2">
                                    <input class="entry-text flex-1 min-w-0 border-0 bg-transparent p-0 text-base font-semibold text-gray-700 sm:border sm:border-gray-200 sm:bg-gray-50 sm:px-3 sm:py-2 sm:text-sm sm:rounded-lg focus:outline-none focus:ring-0 sm:focus:ring"
                                           placeholder="Section name..." value="@ing.Section" />
                                    <button type="button" class="expand-btn text-gray-400 p-1 sm:hidden">
                                        <svg class="expand-chevron w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </button>
                                </div>
                                <div class="detail-panel sm:hidden">
                                    <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between">
                                        <button type="button" class="type-toggle-mobile text-sm text-gray-500 underline">Change to Ingredient</button>
                                        <button type="button" class="remove-entry text-sm text-red-600">Delete</button>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="remove-entry hidden sm:inline text-xs text-red-600 hover:text-red-800">&times;</button>
                        </div>
                    }
                    <div class="entry-row rounded-lg border border-gray-100 bg-white p-3 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:flex sm:items-center sm:gap-2" data-type="ingredient">
                        <span class="drag-handle cursor-grab active:cursor-grabbing text-gray-400 hover:text-gray-600 shrink-0 select-none hidden sm:inline" title="Drag to reorder">&#x2630;</span>
                        <select class="entry-type hidden sm:inline rounded border border-gray-200 text-xs py-1.5 px-1 text-gray-500 bg-white shrink-0">
                            <option value="ingredient" selected>Ingredient</option>
                            <option value="header">Section</option>
                        </select>
                        <div class="entry-content sm:flex-1 sm:flex sm:items-center sm:gap-2">
                            <div class="flex items-center gap-2">
                                <input name="Ingredients[@thisIdx].RawText"
                                       value="@ing.RawText"
                                       class="entry-text flex-1 min-w-0 border-0 bg-transparent p-0 text-base sm:border sm:border-gray-300 sm:rounded-lg sm:px-3 sm:py-2 sm:text-sm focus:outline-none focus:ring-0 sm:focus:ring"
                                       placeholder="e.g., 2 cups flour" />
                                <input type="hidden" name="Ingredients[@thisIdx].SelectedKrogerUpc"
                                       value="@ing.SelectedKrogerUpc" class="selected-upc" />
                                <input type="hidden" name="Ingredients[@thisIdx].Section"
                                       value="@ing.Section" class="ingredient-section" />
                                <span class="product-badge text-xs bg-green-50 text-green-700 rounded-full px-2 py-0.5 whitespace-nowrap sm:hidden @(string.IsNullOrEmpty(ing.SelectedKrogerUpc) ? "hidden" : "")">Linked</span>
                                <button type="button" class="expand-btn text-gray-400 p-1 sm:hidden">
                                    <svg class="expand-chevron w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <div class="hidden sm:flex items-center gap-2">
                                    <button type="button"
                                            class="choose-product-btn text-xs text-red-800 font-medium hover:underline disabled:text-gray-400 disabled:no-underline whitespace-nowrap"
                                            disabled>Link</button>
                                    <span class="product-status text-xs text-gray-400 hidden"></span>
                                    <button type="button"
                                            class="clear-product-btn text-gray-500 hover:text-gray-700 text-sm hidden">&times;</button>
                                </div>
                            </div>
                            <div class="detail-panel sm:hidden">
                                <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between">
                                    <button type="button" class="type-toggle-mobile text-sm text-gray-500 underline">Change to Section</button>
                                    <div class="flex items-center gap-3">
                                        <button type="button" class="choose-product-btn-mobile text-sm text-red-800 font-medium disabled:text-gray-400">Link Product</button>
                                        <button type="button" class="clear-product-btn-mobile text-sm text-gray-500 hidden">Clear</button>
                                        <button type="button" class="remove-entry text-sm text-red-600">Delete</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="remove-entry hidden sm:inline text-xs text-red-600 hover:text-red-800">&times;</button>
                    </div>
                }
            </div>
        </div>

        <!-- Instructions -->
        <div class="bg-white rounded-2xl shadow p-6">
            <div class="flex items-center justify-between gap-3 mb-2">
                <h2 class="text-lg font-semibold">Instructions</h2>

                <button type="button"
                        id="addStepBtn"
                        class="inline-flex items-center rounded-lg bg-gray-900 text-white px-3 py-2 text-sm hover:bg-black">
                    + Add step
                </button>
            </div>

            <div id="stepsContainer" class="space-y-3">
                @if (Model.Instructions != null)
                {
                    @for (int i = 0; i < Model.Instructions.Count; i++)
                    {
                        <div class="step-row" data-step-index="@i">
                            <div class="flex items-center justify-between mb-1 sm:hidden">
                                <span class="step-label text-sm font-semibold text-gray-700">Step @(i + 1)</span>
                                <button type="button" class="remove-step text-sm text-red-600 hover:text-red-800">&times;</button>
                            </div>
                            <div class="sm:flex sm:items-start sm:gap-3">
                                <span class="step-number hidden sm:flex flex-shrink-0 items-center justify-center h-8 w-8 rounded-full bg-red-800 text-white text-sm font-bold mt-1">@(i + 1)</span>
                                <textarea name="Instructions[@i]"
                                          rows="2"
                                          class="w-full sm:flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring"
                                          placeholder="Describe this step...">@Model.Instructions[i]</textarea>
                                <button type="button" class="remove-step hidden sm:inline text-sm text-red-600 hover:text-red-800 px-2 py-1 mt-1 shrink-0">&times;</button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-end gap-3">
            <a asp-action="Recipe" asp-controller="Recipe"
               class="rounded-lg border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50">
                Cancel
            </a>
            <button type="submit"
                    class="rounded-lg bg-green-600 text-white px-5 py-2 text-sm font-semibold hover:bg-green-700">
                Save Recipe
            </button>
        </div>
    </form>
</div>

<!-- Product picker modal -->
<div id="productModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 p-4 z-50">
    <div class="w-full max-w-3xl bg-white rounded-2xl shadow-xl overflow-hidden">
        <!-- Header -->
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-gray-900">Choose Kroger product</h3>
            <button type="button" id="closeProductModal"
                    class="h-9 w-9 inline-flex items-center justify-center rounded-lg hover:bg-gray-100 text-gray-600 hover:text-gray-900">
                <span class="text-2xl leading-none">&times;</span>
            </button>
        </div>

        <!-- Tabs + Search -->
        <div class="px-5 py-4">
            <div class="inline-flex rounded-xl bg-gray-100 p-1">
                <button type="button" id="tabExisting"
                        class="tab-btn px-3 py-1.5 text-sm font-medium rounded-lg bg-white shadow-sm text-gray-900">
                    Search existing
                </button>
                <button type="button" id="tabKroger"
                        class="tab-btn px-3 py-1.5 text-sm font-medium rounded-lg text-gray-700 hover:text-gray-900">
                    Search Kroger
                </button>
            </div>

            <div class="mt-4 flex gap-2">
                <div class="relative flex-1">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 103.5 10.5a7.5 7.5 0 0013.15 6.15z" />
                        </svg>
                    </span>
                    <input id="productSearchInput" type="text"
                           class="w-full rounded-xl border border-gray-200 pl-10 pr-3 py-2 text-sm focus:outline-none focus:ring focus:ring-gray-200"
                           placeholder="Search products…" />
                </div>
                <button type="button" id="productSearchBtn"
                        class="rounded-xl bg-gray-900 text-white px-4 py-2 text-sm font-semibold hover:bg-black">
                    Search
                </button>
            </div>
        </div>

        <!-- Results -->
        <div class="border-t border-gray-100">
            <div id="productResults" class="max-h-[55vh] overflow-y-auto">
                <div class="px-5 py-6 text-sm text-gray-600">
                    Search to see products.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
    <script>
        (function () {
            const container = document.getElementById('ingredientsContainer');

            // Product modal elements
            const productModal = document.getElementById('productModal');
            const closeProductModal = document.getElementById('closeProductModal');
            const productSearchInput = document.getElementById('productSearchInput');
            const tabExisting = document.getElementById('tabExisting');
            const tabKroger = document.getElementById('tabKroger');
            const productSearchBtn = document.getElementById('productSearchBtn');
            const productResults = document.getElementById('productResults');

            let activeRowForProduct = null;
            let searchMode = "existing";

            const ACTIVE_TAB = "tab-btn px-3 py-1.5 text-sm font-medium rounded-lg bg-white shadow-sm text-gray-900";
            const INACTIVE_TAB = "tab-btn px-3 py-1.5 text-sm font-medium rounded-lg text-gray-700 hover:text-gray-900";

            // --- Helpers ---
            function escapeAttr(s) {
                return String(s ?? '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            }

            function getRawText(row) {
                return row.querySelector('.entry-text')?.value?.trim() ?? "";
            }

            function updateProductButtonState(row) {
                const text = getRawText(row);
                const btn = row.querySelector('.choose-product-btn');
                const mobileBtn = row.querySelector('.choose-product-btn-mobile');
                if (btn) btn.disabled = text.length < 2;
                if (mobileBtn) mobileBtn.disabled = text.length < 2;
            }

            function updateProductStatus(row) {
                const upc = row.querySelector('.selected-upc')?.value ?? "";
                const btn = row.querySelector('.choose-product-btn');
                const status = row.querySelector('.product-status');
                const clearBtn = row.querySelector('.clear-product-btn');
                const badge = row.querySelector('.product-badge');
                const mobileBtn = row.querySelector('.choose-product-btn-mobile');
                const mobileClearBtn = row.querySelector('.clear-product-btn-mobile');

                if (!upc) {
                    if (btn) { btn.classList.remove("hidden"); btn.textContent = "Link"; }
                    if (status) { status.classList.add("hidden"); status.textContent = ""; }
                    if (clearBtn) clearBtn.classList.add("hidden");
                    if (badge) badge.classList.add("hidden");
                    if (mobileBtn) mobileBtn.textContent = "Link Product";
                    if (mobileClearBtn) mobileClearBtn.classList.add("hidden");
                } else {
                    if (btn) btn.classList.add("hidden");
                    if (status) { status.classList.remove("hidden"); status.textContent = "Linked"; status.className = "product-status text-xs text-green-700 font-medium"; }
                    if (clearBtn) clearBtn.classList.remove("hidden");
                    if (badge) badge.classList.remove("hidden");
                    if (mobileBtn) mobileBtn.textContent = "Change Link";
                    if (mobileClearBtn) mobileClearBtn.classList.remove("hidden");
                }
            }

            // --- Templates ---
            function entryRowHtml(type, index, text, upc) {
                const isHeader = type === 'header';
                const hasUpc = upc && upc.length > 0;

                if (isHeader) {
                    return `
                    <div class="entry-row rounded-lg border border-gray-100 bg-gray-50 p-3 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:flex sm:items-center sm:gap-2" data-type="header">
                        <span class="drag-handle cursor-grab active:cursor-grabbing text-gray-400 hover:text-gray-600 shrink-0 select-none hidden sm:inline" title="Drag to reorder">&#x2630;</span>
                        <select class="entry-type hidden sm:inline rounded border border-gray-200 text-xs py-1.5 px-1 text-gray-500 bg-white shrink-0">
                            <option value="ingredient">Ingredient</option>
                            <option value="header" selected>Section</option>
                        </select>
                        <div class="entry-content sm:flex-1 sm:flex sm:items-center sm:gap-2">
                            <div class="flex items-center gap-2">
                                <input class="entry-text flex-1 min-w-0 border-0 bg-transparent p-0 text-base font-semibold text-gray-700 sm:border sm:border-gray-200 sm:bg-gray-50 sm:px-3 sm:py-2 sm:text-sm sm:rounded-lg focus:outline-none focus:ring-0 sm:focus:ring"
                                       placeholder="Section name..." value="${escapeAttr(text)}" />
                                <button type="button" class="expand-btn text-gray-400 p-1 sm:hidden">
                                    <svg class="expand-chevron w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                            </div>
                            <div class="detail-panel sm:hidden">
                                <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between">
                                    <button type="button" class="type-toggle-mobile text-sm text-gray-500 underline">Change to Ingredient</button>
                                    <button type="button" class="remove-entry text-sm text-red-600">Delete</button>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="remove-entry hidden sm:inline text-xs text-red-600 hover:text-red-800">&times;</button>
                    </div>`;
                }

                return `
                <div class="entry-row rounded-lg border border-gray-100 bg-white p-3 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:flex sm:items-center sm:gap-2" data-type="ingredient">
                    <span class="drag-handle cursor-grab active:cursor-grabbing text-gray-400 hover:text-gray-600 shrink-0 select-none hidden sm:inline" title="Drag to reorder">&#x2630;</span>
                    <select class="entry-type hidden sm:inline rounded border border-gray-200 text-xs py-1.5 px-1 text-gray-500 bg-white shrink-0">
                        <option value="ingredient" selected>Ingredient</option>
                        <option value="header">Section</option>
                    </select>
                    <div class="entry-content sm:flex-1 sm:flex sm:items-center sm:gap-2">
                        <div class="flex items-center gap-2">
                            <input name="Ingredients[${index}].RawText" value="${escapeAttr(text)}"
                                   class="entry-text flex-1 min-w-0 border-0 bg-transparent p-0 text-base sm:border sm:border-gray-300 sm:rounded-lg sm:px-3 sm:py-2 sm:text-sm focus:outline-none focus:ring-0 sm:focus:ring"
                                   placeholder="e.g., 2 cups flour" />
                            <input type="hidden" name="Ingredients[${index}].SelectedKrogerUpc" value="${escapeAttr(upc)}" class="selected-upc" />
                            <input type="hidden" name="Ingredients[${index}].Section" value="" class="ingredient-section" />
                            <span class="product-badge text-xs bg-green-50 text-green-700 rounded-full px-2 py-0.5 whitespace-nowrap sm:hidden ${hasUpc ? '' : 'hidden'}">Linked</span>
                            <button type="button" class="expand-btn text-gray-400 p-1 sm:hidden">
                                <svg class="expand-chevron w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                            <div class="hidden sm:flex items-center gap-2">
                                <button type="button" class="choose-product-btn text-xs text-red-800 font-medium hover:underline disabled:text-gray-400 disabled:no-underline whitespace-nowrap" disabled>Link</button>
                                <span class="product-status text-xs text-gray-400 hidden"></span>
                                <button type="button" class="clear-product-btn text-gray-500 hover:text-gray-700 text-sm hidden">&times;</button>
                            </div>
                        </div>
                        <div class="detail-panel sm:hidden">
                            <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between">
                                <button type="button" class="type-toggle-mobile text-sm text-gray-500 underline">Change to Section</button>
                                <div class="flex items-center gap-3">
                                    <button type="button" class="choose-product-btn-mobile text-sm text-red-800 font-medium disabled:text-gray-400">Link Product</button>
                                    <button type="button" class="clear-product-btn-mobile text-sm text-gray-500 hidden">Clear</button>
                                    <button type="button" class="remove-entry text-sm text-red-600">Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="remove-entry hidden sm:inline text-xs text-red-600 hover:text-red-800">&times;</button>
                </div>`;
            }

            // --- Reindex & auto-grow ---
            function reindexRows() {
                let idx = 0;
                for (const row of container.querySelectorAll('.entry-row[data-type="ingredient"]')) {
                    row.querySelector('.entry-content').querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/Ingredients\[\d+\]/g, `Ingredients[${idx}]`);
                    });
                    idx++;
                }
            }

            function ensureEmptyRow() {
                const rows = Array.from(container.querySelectorAll('.entry-row'));
                const last = rows[rows.length - 1];
                const lastText = last?.querySelector('.entry-text')?.value?.trim() ?? '';
                const lastType = last?.getAttribute('data-type');
                if (!last || lastText !== '' || lastType === 'header') {
                    const idx = container.querySelectorAll('.entry-row[data-type="ingredient"]').length;
                    container.insertAdjacentHTML('beforeend', entryRowHtml('ingredient', idx, '', ''));
                }
            }

            // --- Type toggle ---
            function handleTypeChange(row, newType) {
                const currentText = row.querySelector('.entry-text')?.value ?? '';
                const currentUpc = row.querySelector('.selected-upc')?.value ?? '';
                const newHtml = entryRowHtml(newType, 0, currentText, currentUpc);
                row.insertAdjacentHTML('afterend', newHtml);
                const newRow = row.nextElementSibling;
                row.remove();
                reindexRows();
                if (newType === 'ingredient') {
                    updateProductButtonState(newRow);
                    updateProductStatus(newRow);
                }
                ensureEmptyRow();
            }

            container.addEventListener('change', function (e) {
                if (e.target.classList.contains('entry-type')) {
                    const row = e.target.closest('.entry-row');
                    const newType = e.target.value;
                    if (newType === row.getAttribute('data-type')) return;
                    handleTypeChange(row, newType);
                }
            });

            // --- Click handlers ---
            container.addEventListener('click', function (e) {
                // Mobile type toggle
                if (e.target.classList.contains('type-toggle-mobile')) {
                    const row = e.target.closest('.entry-row');
                    const currentType = row.getAttribute('data-type');
                    const newType = currentType === 'header' ? 'ingredient' : 'header';
                    handleTypeChange(row, newType);
                    return;
                }

                // Expand/collapse mobile detail panel
                const expandBtn = e.target.closest('.expand-btn');
                if (expandBtn) {
                    const row = expandBtn.closest('.entry-row');
                    const panel = row.querySelector('.detail-panel');
                    const chevron = expandBtn.querySelector('.expand-chevron');
                    panel.classList.toggle('expanded');
                    if (chevron) chevron.classList.toggle('rotate-180');
                    return;
                }

                if (e.target.classList.contains('remove-entry')) {
                    e.target.closest('.entry-row').remove();
                    reindexRows();
                    ensureEmptyRow();
                    return;
                }

                const row = e.target.closest('.entry-row[data-type="ingredient"]');
                if (!row) return;

                if (e.target.classList.contains('choose-product-btn')) {
                    if (e.target.disabled) return;
                    activeRowForProduct = row;
                    e.target.blur();
                    openProductModal(getRawText(row));
                    return;
                }

                if (e.target.classList.contains('choose-product-btn-mobile')) {
                    if (e.target.disabled) return;
                    activeRowForProduct = row;
                    openProductModal(getRawText(row));
                    return;
                }

                if (e.target.classList.contains('clear-product-btn') || e.target.classList.contains('clear-product-btn-mobile')) {
                    row.querySelector('.selected-upc').value = '';
                    updateProductStatus(row);
                    return;
                }
            });

            // --- Input: update product button + auto-grow ---
            container.addEventListener('input', function (e) {
                if (!e.target.classList.contains('entry-text')) return;
                const row = e.target.closest('.entry-row');
                if (row?.getAttribute('data-type') === 'ingredient') updateProductButtonState(row);
                ensureEmptyRow();
            });

            // --- Init existing rows ---
            for (const row of container.querySelectorAll('.entry-row[data-type="ingredient"]')) {
                updateProductButtonState(row);
                updateProductStatus(row);
            }
            ensureEmptyRow();

            // --- Drag-and-drop reordering ---
            const isMobile = window.innerWidth < 640;
            const sortableOpts = {
                animation: 150,
                ghostClass: 'bg-blue-50',
                onEnd: function () {
                    reindexRows();
                    ensureEmptyRow();
                }
            };
            if (isMobile) {
                sortableOpts.delay = 300;
                sortableOpts.delayOnTouchOnly = true;
                sortableOpts.touchStartThreshold = 5;
            } else {
                sortableOpts.handle = '.drag-handle';
            }
            Sortable.create(container, sortableOpts);

            // --- Steps (instructions) ---
            const stepsContainer = document.getElementById('stepsContainer');
            const addStepBtn = document.getElementById('addStepBtn');

            function nextStepIndex() {
                return stepsContainer.querySelectorAll('.step-row').length;
            }

            function reindexSteps() {
                const rows = Array.from(stepsContainer.querySelectorAll('.step-row'));
                rows.forEach((row, newIndex) => {
                    row.setAttribute('data-step-index', newIndex);
                    const num = row.querySelector('.step-number');
                    if (num) num.textContent = newIndex + 1;
                    const label = row.querySelector('.step-label');
                    if (label) label.textContent = `Step ${newIndex + 1}`;
                    const textarea = row.querySelector('textarea');
                    if (textarea) textarea.name = `Instructions[${newIndex}]`;
                });
            }

            const stepTemplate = (index) => `
                <div class="step-row" data-step-index="${index}">
                    <div class="flex items-center justify-between mb-1 sm:hidden">
                        <span class="step-label text-sm font-semibold text-gray-700">Step ${index + 1}</span>
                        <button type="button" class="remove-step text-sm text-red-600 hover:text-red-800">&times;</button>
                    </div>
                    <div class="sm:flex sm:items-start sm:gap-3">
                        <span class="step-number hidden sm:flex flex-shrink-0 items-center justify-center h-8 w-8 rounded-full bg-red-800 text-white text-sm font-bold mt-1">${index + 1}</span>
                        <textarea name="Instructions[${index}]"
                                  rows="2"
                                  class="w-full sm:flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring"
                                  placeholder="Describe this step..."></textarea>
                        <button type="button" class="remove-step hidden sm:inline text-sm text-red-600 hover:text-red-800 px-2 py-1 mt-1 shrink-0">&times;</button>
                    </div>
                </div>
            `;

            addStepBtn.addEventListener('click', function () {
                const idx = nextStepIndex();
                stepsContainer.insertAdjacentHTML('beforeend', stepTemplate(idx));
            });

            stepsContainer.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-step')) {
                    e.target.closest('.step-row').remove();
                    reindexSteps();
                }
            });

            // --- Product modal ---
            function setSearchMode(mode) {
                searchMode = mode;
                tabExisting.className = mode === "existing" ? ACTIVE_TAB : INACTIVE_TAB;
                tabKroger.className = mode === "kroger" ? ACTIVE_TAB : INACTIVE_TAB;
            }

            tabExisting.addEventListener('click', async () => {
                setSearchMode("existing");
                if (productSearchInput.value.trim().length >= 2) {
                    await searchProducts(`/Product/SearchDb?term=${encodeURIComponent(productSearchInput.value.trim())}`);
                }
            });

            tabKroger.addEventListener('click', async () => {
                setSearchMode("kroger");
                if (productSearchInput.value.trim().length >= 2) {
                    await searchProducts(`/Product/SearchKroger?term=${encodeURIComponent(productSearchInput.value.trim())}`);
                }
            });

            function escapeHtml(str) {
                return String(str ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            function openProductModal(prefill = '') {
                setSearchMode("existing");
                productSearchInput.value = prefill ?? '';
                productResults.innerHTML = `<div class="px-3 py-3 text-sm text-gray-600">Search to see products.</div>`;
                productModal.classList.remove('hidden');
                productModal.classList.add('flex');
                productSearchInput.focus();

                if (productSearchInput.value.trim().length >= 2) {
                    productSearchBtn.click();
                }
            }

            function closeModal() {
                productModal.classList.add('hidden');
                productModal.classList.remove('flex');
                activeRowForProduct = null;
            }

            closeProductModal.addEventListener('click', closeModal);
            productModal.addEventListener('click', (e) => {
                if (e.target === productModal) closeModal();
            });

            function productImageUrl(upc) {
                const clean = String(upc ?? '').trim();
                return clean ? `https://www.kroger.com/product/images/medium/front/${encodeURIComponent(clean)}` : "";
            }

            function renderProducts(data) {
                if (!Array.isArray(data) || data.length === 0) {
                    productResults.innerHTML = `<div class="px-3 py-3 text-sm text-gray-600">No results</div>`;
                    return;
                }

                productResults.innerHTML = data.map(p => {
                    const upc = escapeHtml(p.upc ?? p.Upc ?? '');
                    const name = escapeHtml(p.name ?? p.Name ?? '');
                    const sub = escapeHtml(p.size ?? p.Size ?? p.brand ?? p.Brand ?? '');
                    const img = productImageUrl(upc);

                    return `
                        <button type="button"
                                class="product-result-item w-full text-left px-3 py-3 border-b border-gray-100 hover:bg-gray-50"
                                data-upc="${upc}"
                                data-name="${name}">
                            <div class="flex items-center gap-3">
                                <div class="h-12 w-12 rounded-lg border border-gray-200 bg-white overflow-hidden flex items-center justify-center shrink-0">
                                    <img src="${img}" alt="" class="h-full w-full object-cover" loading="lazy"
                                         onerror="this.onerror=null; this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2248%22 height=%2248%22><rect width=%2248%22 height=%2248%22 fill=%22%23f3f4f6%22/></svg>';" />
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="text-sm font-medium text-gray-900 truncate">${name}</div>
                                    <div class="text-xs text-gray-500 mt-1 flex items-center justify-between gap-3">
                                        <span class="truncate">${sub}</span>
                                        <span class="text-gray-400 shrink-0">UPC: ${upc}</span>
                                    </div>
                                </div>
                            </div>
                        </button>
                    `;
                }).join('');
            }

            async function searchProducts(url) {
                const q = productSearchInput.value.trim();
                if (!q) return;
                productResults.innerHTML = `<div class="px-3 py-3 text-sm text-gray-600">Searching…</div>`;
                try {
                    const res = await fetch(url);
                    if (!res.ok) throw new Error('Search failed');
                    const data = await res.json();
                    renderProducts(data);
                } catch {
                    productResults.innerHTML = `<div class="px-3 py-3 text-sm text-red-600">Search error</div>`;
                }
            }

            productSearchBtn.addEventListener('click', async () => {
                const term = productSearchInput.value.trim();
                if (term.length < 2) return;
                const url = (searchMode === "existing")
                    ? `/Product/SearchDb?term=${encodeURIComponent(term)}`
                    : `/Product/SearchKroger?term=${encodeURIComponent(term)}`;
                await searchProducts(url);
            });

            productSearchInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') { e.preventDefault(); productSearchBtn.click(); }
            });

            productResults.addEventListener('click', (e) => {
                const btn = e.target.closest('.product-result-item');
                if (!btn || !activeRowForProduct) return;
                const upc = btn.getAttribute('data-upc') ?? '';
                activeRowForProduct.querySelector('.selected-upc').value = upc;
                updateProductStatus(activeRowForProduct);
                closeModal();
            });

            // --- Submit: assign sections from headers to ingredient rows ---
            document.querySelector('form').addEventListener('submit', function () {
                let currentSection = '';
                for (const row of container.querySelectorAll('.entry-row')) {
                    if (row.getAttribute('data-type') === 'header') {
                        currentSection = row.querySelector('.entry-text')?.value?.trim() ?? '';
                    } else if (row.getAttribute('data-type') === 'ingredient') {
                        const sectionInput = row.querySelector('.ingredient-section');
                        if (sectionInput) sectionInput.value = currentSection;
                    }
                }
                reindexRows();
            });
        })();
    </script>
}
