@model ViewRecipeVM

@{
    ViewData["Title"]    = Model.RecipeName;
    ViewData["NavTitle"] = Model.RecipeName;
    ViewData["BackLink"]  = Url.Action("Recipe", "Recipe");
    ViewData["BackLabel"] = "Recipes";
    var hasImage        = !string.IsNullOrWhiteSpace(Model?.ImageUri);
    var hasIngredients  = Model.Ingredients != null && Model.Ingredients.Any();
    var hasInstructions = Model.Instructions != null && Model.Instructions.Any();
}

@section NavRight {
    <a asp-controller="Recipe" asp-action="CreateEditRecipe" asp-route-id="@Model.Id"
       class="ios-btn-text" style="font-size:17px;">Edit</a>
}

<!-- Hero image — full bleed -->
@if (hasImage)
{
    <div class="w-full overflow-hidden" style="aspect-ratio: 16/9; max-height: 260px; background: var(--ios-fill);">
        <img src="@Model.ImageUri"
             alt="@Model.RecipeName"
             class="w-full h-full object-cover" />
    </div>
}

<div class="pb-8 @(hasImage ? "pt-0" : "pt-2")">

    <!-- Title + meta -->
    <div class="px-4 pt-4 pb-2">
        <h1 class="text-[22px] font-bold leading-tight" style="color: var(--ios-label); letter-spacing: -0.3px;">
            @Model.RecipeName
        </h1>
        <div class="flex flex-wrap items-center gap-2 mt-1.5">
            @if (!string.IsNullOrEmpty(Model.DinnerCategory))
            {
                <span class="ios-badge">@Model.DinnerCategory</span>
            }
            @if (!string.IsNullOrEmpty(Model.SourceUrl))
            {
                <a href="@Model.SourceUrl" target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1 text-[13px]" style="color: var(--ios-label-2);">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
                    </svg>
                    Original recipe
                </a>
            }
        </div>
    </div>

    <!-- Delete action -->
    <div class="px-4 pb-4">
        <form asp-controller="Recipe" asp-action="DeleteRecipe" asp-route-id="@Model.Id" method="post" class="inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="ios-btn-text-destructive text-[13px]"
                    onclick="return confirm('Delete this recipe?');">
                Delete recipe
            </button>
        </form>
    </div>

    <!-- Ingredients -->
    @if (hasIngredients)
    {
        <p class="ios-section-hdr">
            Ingredients
            <span class="ios-badge ios-badge-gray ml-1">@Model.Ingredients.Count</span>
        </p>
        <div class="ios-group">
            @{
                string? lastSection = null;
            }
            @foreach (var ingredient in Model.Ingredients)
            {
                if (ingredient.Section != lastSection)
                {
                    lastSection = ingredient.Section;
                    if (!string.IsNullOrEmpty(lastSection))
                    {
                        <div class="px-4 py-2 text-[12px] font-semibold uppercase tracking-wide"
                             style="color: var(--ios-label-2); background: rgba(242,242,247,0.6); border-bottom: 0.5px solid var(--ios-separator);">
                            @lastSection
                        </div>
                    }
                }
                <div class="ios-cell">
                    <span class="text-[15px] font-semibold min-w-[72px]" style="color: var(--ios-label);">
                        @ingredient.DisplayQuantity @ingredient.DisplayMeasurement
                    </span>
                    <span class="text-[15px] flex-1" style="color: var(--ios-label-2);">
                        @ingredient.Name
                    </span>
                </div>
            }
        </div>
    }
    else
    {
        <p class="ios-section-hdr">Ingredients</p>
        <div class="ios-group">
            <div class="ios-cell">
                <span class="text-[15px]" style="color: var(--ios-label-2);">No ingredients listed yet.</span>
            </div>
        </div>
    }

    <!-- Instructions -->
    @if (hasInstructions)
    {
        <p class="ios-section-hdr">
            Instructions
            <span class="ios-badge ios-badge-gray ml-1">@Model.Instructions.Count step@(Model.Instructions.Count == 1 ? "" : "s")</span>
        </p>
        <div class="ios-group">
            <ol id="stepsOl">
                @for (var i = 0; i < Model.Instructions.Count; i++)
                {
                    <li class="step-item ios-cell cursor-pointer select-none transition-colors"
                        data-step="@i" style="align-items: flex-start; padding: 14px 16px;">
                        <span class="step-number flex-shrink-0 flex items-center justify-center h-7 w-7 rounded-full text-white text-[12px] font-bold mt-0.5 transition-all"
                              style="background: var(--ios-red); min-width: 28px;">
                            @(i + 1)
                        </span>
                        <span class="text-[15px] leading-relaxed flex-1 break-words" style="color: var(--ios-label);">
                            @Model.Instructions[i]
                        </span>
                    </li>
                }
            </ol>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const ol = document.getElementById('stepsOl');
            if (!ol) return;

            ol.addEventListener('click', function (e) {
                const li = e.target.closest('.step-item');
                if (!li) return;

                const wasActive = li.classList.contains('is-active');

                ol.querySelectorAll('.step-item.is-active').forEach(el => {
                    el.classList.remove('is-active');
                    el.style.background = '';
                    const num = el.querySelector('.step-number');
                    if (num) { num.style.background = 'var(--ios-red)'; num.style.transform = ''; }
                });

                if (wasActive) return;

                li.classList.add('is-active');
                li.style.background = 'rgba(255,59,48,0.06)';
                const num = li.querySelector('.step-number');
                if (num) { num.style.background = '#CC2F26'; num.style.transform = 'scale(1.1)'; }
            });
        })();
    </script>
}
